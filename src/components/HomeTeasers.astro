<section class="about-teaser container section-py">
  <div class="teaser-glass glass-card">
    <div class="teaser-text">
      <h2 class="font-heading teaser-title" data-i18n="home.about.title">Kenali Saya Lebih Jauh</h2>
      <p class="text-muted teaser-desc" data-i18n="home.about.desc">
        Saya Fatahilah, lulusan TKJ dengan minat mendalam pada otomasi AI dan infrastruktur server. Saya senang memecahkan masalah kompleks dan membangun sistem yang stabil serta efisien.
      </p>
      <a href="/about" class="btn-secondary" data-i18n="home.about.btn">
        Baca Profil Lengkap
      </a>
    </div>
    
    <div class="teaser-contact">
      <h3 class="font-heading teaser-subtitle" data-i18n="home.contact.title">Tertarik Bekerja Sama?</h3>
      <p class="text-muted teaser-contact-desc" data-i18n="home.contact.desc">
        Saya selalu terbuka untuk peluang karir, proyek freelance, atau diskusi teknis seputar IT.
      </p>
      <a href="/contact" class="btn-primary" data-i18n="home.contact.btn">
        Hubungi Saya Sekarang
      </a>
    </div>
  </div>
</section>

<style>
  .teaser-glass {
    padding: 3rem;
    border-radius: 1rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .teaser-text {
    text-align: center;
  }

  .teaser-title {
    font-size: 1.875rem;
    margin-bottom: 1rem;
  }

  .teaser-desc {
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .teaser-contact {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .teaser-subtitle {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .teaser-contact-desc {
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }

  @media (min-width: 768px) {
    .teaser-glass {
      flex-direction: row;
      align-items: center;
      gap: 2rem;
    }

    .teaser-text {
      flex: 1;
      text-align: left;
    }

    .teaser-contact {
      flex: 1;
      padding-top: 0;
      padding-left: 2rem;
      border-top: none;
      border-left: 1px solid var(--color-border);
      text-align: right;
    }
  }
</style>
