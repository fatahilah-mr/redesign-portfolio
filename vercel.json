{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "fatahilah-portofolio.vercel.app"
        }
      ],
      "destination": "https://fatahmr.my.id/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*).(webp|css|js|txt|xml)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
