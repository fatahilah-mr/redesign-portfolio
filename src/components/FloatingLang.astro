  function applyLanguage(lang) {
    document.documentElement.lang = lang;
    localStorage.setItem('lang', lang);

    // Update floating button visual
    const codeEl = document.getElementById('current-lang-code');
    if (codeEl) {
      codeEl.textContent = lang === 'en' ? 'EN' : 'ID';
    }

    // Update all elements with data-i18n attribute
    const dict = window.__DICTIONARY[lang] || window.__DICTIONARY['id'];
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (key && dict[key]) {
        if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
          el.placeholder = dict[key];
        } else if (el.hasAttribute('data-i18n-html')) {
          el.innerHTML = dict[key];
        } else if (!el.querySelector('svg')) {
          el.textContent = dict[key];
        } else {
          // If element contains an SVG icon, only update text spans or aria attributes so SVG is preserved
          const textSpan = el.querySelector('span, .btn-text');
          if (textSpan) {
            textSpan.textContent = dict[key];
          } else {
            if (el.hasAttribute('aria-label')) el.setAttribute('aria-label', dict[key]);
            if (el.hasAttribute('title')) el.setAttribute('title', dict[key]);
          }
        }
      }
    });

    // Announce to screen readers
    const announcer = document.getElementById('a11y-announcer');
    if (announcer) {
      announcer.textContent = lang === 'en' ? 'Language switched to English' : 'Bahasa diganti ke Indonesia';
    }
    window.dispatchEvent(new CustomEvent('languagechange', { detail: { lang } }));
  }
  window.applyLanguage = applyLanguage;

  function setupLangToggle() {
    const btn = document.getElementById('lang-toggle-btn');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const current = localStorage.getItem('lang') || 'id';
      const next = current === 'id' ? 'en' : 'id';
      applyLanguage(next);
    });

    // Apply saved or initial language on load
    const saved = localStorage.getItem('lang') || 'id';
    applyLanguage(saved);
  }

  document.addEventListener('DOMContentLoaded', setupLangToggle);
</script>
