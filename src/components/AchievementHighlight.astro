---
---

<section class="achievement-highlight container section-py">
  <div class="achievement-glass glass-card">
    <div class="achievement-image-wrap">
      <img src="/assets/certificates/sertifikat-lks.webp" alt="Sertifikat Juara 1 LKS IT Network System Administration Tingkat Kabupaten Purworejo 2026" loading="lazy" />
      <div class="achievement-badge-float">
        <span class="badge badge-gold font-mono">Top Achievement</span>
      </div>
    </div>
    
    <div class="achievement-content">
      <div class="badge-wrapper mb-3">
        <span class="badge badge-primary font-mono text-xs uppercase tracking-wider">Lomba Kompetensi Siswa 2026</span>
      </div>
      <h2 class="font-heading achievement-title" data-i18n="home.achievement.title">
        Juara 1 LKS Kabupaten Purworejo
      </h2>
      <p class="text-muted achievement-desc" data-i18n="home.achievement.desc">
        Pencapaian terbesar saya di tahun 2026. Meraih medali emas pada Lomba Kompetensi Siswa (LKS) tingkat Kabupaten dalam bidang lomba <strong>IT Network System Administration</strong>. Membuktikan kompetensi tingkat lanjut dalam membangun dan mengamankan infrastruktur jaringan yang kompleks.
      </p>
      
      <div class="achievement-meta">
        <div class="meta-item">
          <span class="meta-label">Bidang:</span>
          <span class="meta-value">IT Network System Administration</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Penyelenggara:</span>
          <span class="meta-value">Dinas Pendidikan dan Kebudayaan</span>
        </div>
      </div>

      <a href="/certificates" class="btn-primary mt-6 inline-flex" data-i18n="home.achievement.btn">
        Lihat Semua Sertifikat →
      </a>
    </div>
  </div>
</section>

<style>
  .achievement-highlight {
    margin-bottom: 2rem;
  }

  .achievement-glass {
    border-radius: 1.25rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-color: var(--color-accent);
    box-shadow: 0 0 25px rgba(245, 158, 11, 0.08);
  }

  .achievement-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .achievement-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  
  .achievement-glass:hover .achievement-image-wrap img {
    transform: scale(1.02);
  }

  .achievement-badge-float {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 10;
  }

  .achievement-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .achievement-title {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: var(--color-foreground);
    line-height: 1.3;
  }

  .achievement-desc {
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .achievement-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .meta-item {
    font-size: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .meta-label {
    color: var(--color-muted);
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .meta-value {
    color: var(--color-foreground);
    font-weight: 500;
  }

  /* Badge Gold Khusus */
  .badge-gold {
    background-color: rgba(245, 158, 11, 0.15);
    color: var(--color-accent);
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  @media (min-width: 768px) {
    .achievement-glass {
      flex-direction: row;
    }
    
    .achievement-image-wrap {
      width: 50%;
      border-bottom: none;
      border-right: 1px solid var(--color-border);
    }
    
    .achievement-content {
      width: 50%;
      padding: 3rem;
    }
    
    .achievement-meta {
      flex-direction: row;
      gap: 2rem;
    }
  }
</style>
