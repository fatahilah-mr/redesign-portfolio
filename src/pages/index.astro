---
import Layout from '../layouts/Layout.astro';
import AchievementHighlight from '../components/AchievementHighlight.astro';
import ExperienceShowcase from '../components/ExperienceShowcase.astro';
import FeaturedProjects from '../components/FeaturedProjects.astro';
import HomeTeasers from '../components/HomeTeasers.astro';
---

<Layout title="Beranda" description="Portofolio Fatahilah Miftahul Rahman - Juara 1 LKS IT Network System Administration & AI Prompt Engineering Specialist">
  <!-- Hero Section (Tanpa Foto Profil, Khusus di About) -->
  <section class="hero-section container section-py">
    <div class="hero-inner flex flex-col items-center justify-center text-center w-full max-w-4xl mx-auto">
      <div class="hero-text flex flex-col items-center text-center w-full">
        <!-- Eyebrow -->
        <div class="badge-wrapper mb-4 animate-fade-in">
          <span class="badge badge-primary font-mono text-sm uppercase tracking-wider px-4 py-1.5" data-i18n="hero.eyebrow">
            IT Network &amp; System Administration
          </span>
        </div>

        <!-- Main Heading -->
        <h1 class="hero-name font-heading text-4xl sm:text-5xl md:text-6xl text-foreground leading-tight mb-4 animate-slide-up" data-i18n="hero.title" data-i18n-html="true">
          Fatahilah<br />Miftahul Rahman
        </h1>

        <!-- Subtitle / Tagline -->
        <p class="hero-tagline text-muted text-lg sm:text-xl font-light mb-8 max-w-xl mx-auto animate-slide-up-delay" data-i18n="hero.subtitle">
          Connecting the future, one network at a time.
        </p>

        <!-- CTA Buttons -->
        <div class="hero-actions flex flex-wrap items-center justify-center gap-4 animate-slide-up-delay-2">
          <a href="/projects" class="btn-primary" data-i18n="hero.cta.primary">
            Lihat Portofolio →
          </a>
          <a href="/contact" class="btn-secondary" data-i18n="hero.cta.secondary">
            Hubungi Saya
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Showcase Pengalaman PKL & Kerja -->
  <ExperienceShowcase />

  <!-- Highlight Pencapaian Terbesar -->
  <AchievementHighlight />

  <!-- Teaser Sections (Proyek Unggulan & Tentang/Kontak) -->
  <FeaturedProjects />
  <HomeTeasers />

</Layout>

<style>
  .hero-section {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(85vh - 72px);
    text-align: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 860px;
  }

  .badge-wrapper {
    margin-bottom: 24px;
  }

  .hero-title {
    margin-bottom: 20px;
  }

  .hero-subtitle {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 760px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 56px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
    max-width: 780px;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    gap: 6px;
  }

  .stat-number {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
  }

  .text-accent { color: var(--color-accent); }
  .text-primary { color: var(--color-primary); }

  .stat-label {
    font-size: 0.8125rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Highlights Section */
  .highlights-section {
    padding-top: 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 28px;
  }

  .highlight-item {
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .icon-box {
    width: 54px;
    height: 54px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
  }

  .icon-blue { background: rgba(59, 130, 246, 0.12); color: var(--color-primary); }
  .icon-cyan { background: rgba(6, 182, 212, 0.12); color: var(--color-cyan); }
  .icon-gold { background: rgba(245, 158, 11, 0.12); color: var(--color-accent); }

  .highlight-title {
    font-size: 1.25rem;
  }

  .highlight-desc {
    font-size: 0.95rem;
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .hero-stats {
      grid-template-columns: 1fr;
    }
  }

  /* Micro-animations (respecting prefers-reduced-motion) */
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in { animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-slide-up { animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both; }
  .animate-slide-up-delay { animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both; }
  .animate-slide-up-delay-2 { animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both; }
  .animate-fade-in-late { animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both; }
</style>
