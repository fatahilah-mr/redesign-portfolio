---
import { ui, defaultLang } from '../i18n/ui';
---

<div class="floating-lang-wrapper">
  <button 
    id="lang-toggle-btn" 
    class="floating-lang-btn" 
    aria-label="Switch between Indonesian and English language"
    title="Ganti Bahasa / Switch Language"
  >
    <span class="lang-flag" id="current-lang-flag" aria-hidden="true">
      <svg class="flag-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="14" viewBox="0 0 20 14" aria-hidden="true">
        <rect width="20" height="7" fill="#E70011"/>
        <rect y="7" width="20" height="7" fill="#FFFFFF"/>
      </svg>
    </span>
    <span class="lang-text font-mono" id="current-lang-code">ID</span>
  </button>
</div>

<style>
  .floating-lang-wrapper {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 990;
  }

  .floating-lang-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 9999px;
    background: var(--bg-card);
    border: 1px solid var(--color-border);
    color: var(--color-foreground);
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    box-shadow: var(--shadow-md);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .floating-lang-btn:hover {
    transform: translateY(-3px) scale(1.02);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-lg), 0 0 15px var(--color-primary-glow);
    background: var(--bg-card-hover);
  }

  .lang-flag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .flag-icon {
    border-radius: 3px;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.25);
    display: block;
  }

  .lang-text {
    letter-spacing: 0.05em;
  }
</style>

