---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Beranda" description="Portofolio Fatahilah Miftahul Rahman - Juara 1 LKS IT Network System Administration & AI Prompt Engineering Specialist">
  <!-- Hero Section (Mengikuti acuan_dari_web_portofolio/index.html #home) -->
  <section class="hero-section container section-py">
    <div class="hero-inner flex flex-col md:flex-row items-center justify-between gap-12 w-full max-w-5xl mx-auto">
      <div class="hero-text flex flex-col items-center md:items-start text-center md:text-left flex-grow">
        <!-- Eyebrow -->
        <div class="badge-wrapper mb-4 animate-fade-in">
          <span class="badge badge-primary font-mono text-sm uppercase tracking-wider px-4 py-1.5" data-i18n="hero.eyebrow">
            IT Network &amp; System Administration
          </span>
        </div>

        <!-- Main Heading -->
        <h1 class="hero-name font-heading text-4xl sm:text-5xl md:text-6xl text-foreground leading-tight mb-4 animate-slide-up" data-i18n="hero.title">
          Fatahilah<br />Miftahul Rahman
        </h1>

        <!-- Subtitle / Tagline -->
        <p class="hero-tagline text-muted text-lg sm:text-xl font-light mb-8 max-w-xl animate-slide-up-delay" data-i18n="hero.subtitle">
          Connecting the future, one network at a time.
        </p>

        <!-- CTA Buttons -->
        <div class="hero-actions flex flex-wrap items-center justify-center md:justify-start gap-4 mb-10 animate-slide-up-delay-2">
          <a href="/projects" class="btn-primary" data-i18n="hero.cta.primary">
            Lihat Portofolio →
          </a>
          <a href="/contact" class="btn-secondary" data-i18n="hero.cta.secondary">
            Hubungi Saya
          </a>
        </div>

        <!-- Quick Stats Showcase -->
        <div class="hero-stats grid grid-cols-3 gap-4 w-full max-w-lg animate-fade-in-late">
          <div class="stat-card glass-card p-4 rounded-xl border border-border text-center">
            <span class="stat-number font-heading text-2xl block text-foreground">99.9%</span>
            <span class="stat-label font-mono text-xs text-muted block mt-1" data-i18n="hero.stat.uptime">Target Uptime</span>
          </div>
          <div class="stat-card glass-card p-4 rounded-xl border border-border text-center">
            <span class="stat-number font-heading text-2xl block text-accent">#1</span>
            <span class="stat-label font-mono text-xs text-muted block mt-1" data-i18n="hero.stat.lks">Juara 1 LKS 2026</span>
          </div>
          <div class="stat-card glass-card p-4 rounded-xl border border-border text-center">
            <span class="stat-number font-heading text-2xl block text-primary">LLM</span>
            <span class="stat-label font-mono text-xs text-muted block mt-1" data-i18n="hero.stat.ai">AI Prompt Automated</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Feature Highlights -->
  <section class="highlights-section container section-py">
    <div class="section-header">
      <h2 class="font-heading" data-i18n="about.title">Filosofi Teknis & Core Keahlian</h2>
    </div>

    <div class="highlights-grid">
      <div class="highlight-item glass-card">
        <div class="icon-box icon-blue">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="16" height="16" x="4" y="4" rx="2"></rect>
            <rect width="6" height="6" x="9" y="9" rx="1"></rect>
            <path d="M15 2v2"></path><path d="M15 20v2"></path><path d="M2 15h2"></path><path d="M2 9h2"></path><path d="M20 15h2"></path><path d="M20 9h2"></path><path d="M9 2v2"></path><path d="M9 20v2"></path>
          </svg>
        </div>
        <h3 class="highlight-title" data-i18n="about.phil.card1.title">1. Keamanan & Keandalan (Uptime 99.9%)</h3>
        <p class="highlight-desc" data-i18n="about.phil.card1.desc">Infrastruktur tidak boleh lengah. Saya menerapkan segmentasi VLAN, firewall ketat, dan redundansi protokol.</p>
      </div>

      <div class="highlight-item glass-card">
        <div class="icon-box icon-cyan">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="4 17 10 11 4 5"></polyline>
            <line x1="12" x2="20" y1="19" y2="19"></line>
          </svg>
        </div>
        <h3 class="highlight-title" data-i18n="about.phil.card2.title">2. Otomatisasi Efisien</h3>
        <p class="highlight-desc" data-i18n="about.phil.card2.desc">Menghemat waktu dengan otomatisasi skrip shell dan diagnosa berbantuan AI untuk efisiensi sistem.</p>
      </div>

      <div class="highlight-item glass-card">
        <div class="icon-box icon-gold">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
            <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
            <path d="M4 22h16"></path>
            <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path>
            <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path>
            <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path>
          </svg>
        </div>
        <h3 class="highlight-title" data-i18n="about.phil.card3.title">3. Pembelajaran Berkelanjutan</h3>
        <p class="highlight-desc" data-i18n="about.phil.card3.desc">Teknologi jaringan dan AI berkembang pesat. Saya selalu menguji teknologi terbaru di laboratorium virtual.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero-section {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(85vh - 72px);
    text-align: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 860px;
  }

  .badge-wrapper {
    margin-bottom: 24px;
  }

  .hero-title {
    margin-bottom: 20px;
  }

  .hero-subtitle {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 760px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 56px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
    max-width: 780px;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    gap: 6px;
  }

  .stat-number {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
  }

  .text-accent { color: var(--color-accent); }
  .text-primary { color: var(--color-primary); }

  .stat-label {
    font-size: 0.8125rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Highlights Section */
  .highlights-section {
    padding-top: 2rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 28px;
  }

  .highlight-item {
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .icon-box {
    width: 54px;
    height: 54px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
  }

  .icon-blue { background: rgba(59, 130, 246, 0.12); color: var(--color-primary); }
  .icon-cyan { background: rgba(6, 182, 212, 0.12); color: var(--color-cyan); }
  .icon-gold { background: rgba(245, 158, 11, 0.12); color: var(--color-accent); }

  .highlight-title {
    font-size: 1.25rem;
  }

  .highlight-desc {
    font-size: 0.95rem;
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .hero-stats {
      grid-template-columns: 1fr;
    }
  }

  /* Micro-animations (respecting prefers-reduced-motion) */
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in { animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-slide-up { animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both; }
  .animate-slide-up-delay { animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both; }
  .animate-slide-up-delay-2 { animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both; }
  .animate-fade-in-late { animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both; }
</style>
