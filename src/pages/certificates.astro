---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sertifikat & Pencapaian" description="Galeri arsip digital sertifikasi, transkrip nilai, dan pencapaian LKS Fatahilah Miftahul Rahman di bidang IT Network & System Administration.">
  <section class="certificates-section container section-py">
    <div class="section-header">
      <div class="back-btn-wrap mb-6 flex justify-center">
        <a href="/" class="btn-secondary text-xs py-2 px-4 flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          <span>Kembali ke Beranda</span>
        </a>
      </div>

      <div class="section-badge flex justify-center items-center gap-3">
        <span class="badge font-mono" data-i18n="nav.certificates">Arsip Digital</span>
        <span class="badge badge-gold font-mono">Terverifikasi</span>
      </div>
      <h1 class="font-heading" data-i18n="certs.title">Semua Sertifikat & Transkrip</h1>
      <p class="section-subtitle">
        Dokumentasi resmi kelulusan kompetensi, transkrip nilai Praktik Kerja Lapangan (PKL), serta penghargaan kompetisi LKS.
      </p>

      <!-- CMS Toolbar & Refresh Button -->
      <div class="cms-toolbar mt-6 flex flex-wrap justify-center items-center gap-4">
        <button id="refresh-cms-btn" class="btn-refresh font-mono text-xs flex items-center gap-2" aria-label="Segarkan data Sertifikat dari Google Sheets">
          <svg class="refresh-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
          <span>↻ Segarkan Data CMS</span>
        </button>
        <span id="cms-cache-status" class="cache-status font-mono text-xs text-muted">Status: Memuat data...</span>
      </div>
    </div>

    <!-- Dynamic Certificates Grid Container (Sesuai ID di cms-certificates.js) -->
    <div id="cert-grid-dynamic" class="cert-grid" aria-live="polite">
      <div class="loading-status glass-card p-12 text-center col-span-full">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary mb-4"></div>
        <p class="font-heading text-lg">Menghubungkan ke API Google Sheets...</p>
        <p class="text-muted text-sm mt-1">Mengambil arsip sertifikat terbaru dari server</p>
      </div>
    </div>

    <!-- Tombol Google Drive -->
    <div class="mt-14 text-center flex justify-center">
      <a class="cert-drive-btn glass-card flex items-center justify-center gap-3 py-4 px-8 rounded-full font-medium hover:border-primary transition-all" href="https://drive.google.com/drive/folders/1jxQi8S0QpUtACRlumbORdfEAGRturCqt" target="_blank" rel="noopener">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="var(--color-primary)"><path d="M4.433 22l-2.9-5.02 5.4-9.35h5.8L4.433 22zm4.4-9.35L5.733 7.63 11.133 0h5.8l-5.4 9.35H8.833zm11.167 9.35H7.333l2.9-5H19.4l2.9 5h-2.3z"/></svg>
        <span>Buka Folder Sertifikat Lengkap di Google Drive</span>
      </a>
    </div>
  </section>

  <!-- Modal untuk Preview Transkrip Nilai (Accessible WCAG AA) -->
  <div id="certModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle" tabindex="-1">
    <div class="modal-backdrop"></div>
    <div class="modal-dialog">
      <div class="modal-header">
        <span id="modalTitle" class="font-heading text-lg">Preview Transkrip & Lampiran</span>
        <button class="close-modal" id="closeModal" aria-label="Tutup Modal">&times;</button>
      </div>
      <div class="modal-body">
        <img class="modal-content" id="modalImg" alt="Halaman Lampiran Sertifikat / Transkrip Nilai" />
      </div>
    </div>
  </div>
</Layout>

<!-- CMS Logic Script (Exact from cms logic/halaman sertifikat/cms-certificates.js with 1h localStorage caching & a11y focus trap) -->
<script is:inline>
(function() {
  const SPREADSHEET_ID = '1GtKyr8LGv5AfSChzfP7t6_4D0rBUoC8VeRdC_Rw6eqY';
  const SHEET_NAME = 'Sheet1';
  const DATA_URL = `https://docs.google.com/spreadsheets/d/${SPREADSHEET_ID}/gviz/tq?tqx=out:json&sheet=${SHEET_NAME}`;
  const CACHE_KEY = 'portfolio_certificates_cache_v2';
  const CACHE_TIME_KEY = 'portfolio_certificates_cache_time_v2';
  const CACHE_DURATION_MS = 3600000; // 1 jam

  const container = document.getElementById('cert-grid-dynamic');
  const modal = document.getElementById('certModal');
  const modalImg = document.getElementById('modalImg');
  const closeModalBtn = document.getElementById('closeModal');
  const refreshBtn = document.getElementById('refresh-cms-btn');
  const cacheStatus = document.getElementById('cms-cache-status');

  let activeTriggerButton = null;

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/[&<>'"]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      if (m === "'") return '&#039;';
      if (m === '"') return '&quot;';
      return m;
    });
  }

  function updateCacheStatusText(msg) {
    if (cacheStatus) cacheStatus.textContent = msg;
  }

  function openModal(imgSrc, triggerBtn) {
    if (modal && modalImg) {
      activeTriggerButton = triggerBtn || document.activeElement;
      modalImg.src = imgSrc;
      modal.classList.add('show');
      if (closeModalBtn) closeModalBtn.focus();
      document.body.style.overflow = 'hidden';
    }
  }

  function closeModal() {
    if (modal) {
      modal.classList.remove('show');
      document.body.style.overflow = '';
      setTimeout(() => { if (modalImg) modalImg.src = ''; }, 300);
      if (activeTriggerButton && typeof activeTriggerButton.focus === 'function') {
        activeTriggerButton.focus();
      }
    }
  }

  if (closeModalBtn) closeModalBtn.addEventListener('click', closeModal);
  if (modal) {
    modal.addEventListener('click', function(e) {
      if (e.target === modal || e.target.classList.contains('modal-backdrop')) {
        closeModal();
      }
    });
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal && modal.classList.contains('show')) {
      closeModal();
    }
  });

  function renderCertificates(certificates) {
    if (!container) return;
    if (!certificates.length) {
      container.innerHTML = `<div class="loading-status glass-card p-12 text-center col-span-full">📭 Belum ada sertifikat. Silakan tambahkan data di Google Sheets.</div>`;
      return;
    }

    container.innerHTML = '';
    certificates.forEach(cert => {
      const isFeatured = (cert.id === '1' || cert.id === 1);
      const additionalClass = cert.tipe === 'vertical' ? 'pkl-vertical' : '';
      const featuredClass = isFeatured ? 'featured-cert' : '';
      const card = document.createElement('div');
      card.className = `cert-card glass-card ${additionalClass} ${featuredClass}`;

      const imgHtml = `<img src="${cert.imgDepan}" alt="${escapeHtml(cert.nama)}" loading="lazy" onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='flex';">`;
      const fallbackDiv = `<div class="cert-img-fallback" style="display:none; align-items:center; justify-content:center; width:100%; min-height:220px; background:var(--bg-surface); color:var(--color-muted); font-size:0.88rem; padding:16px; text-align:center; font-weight:500;">📄 ${escapeHtml(cert.nama)}</div>`;

      let buttonHtml = '';
      if (cert.tombolAda && cert.imgBelakang) {
        buttonHtml = `<button class="btn-transkrip btn-secondary w-full py-2.5 mt-auto text-xs font-mono flex justify-center items-center gap-2" data-fullimg="${cert.imgBelakang}"><span>📄 Lihat Transkrip</span></button>`;
      }

      let metaText = '';
      if (cert.penerbit && cert.tahun) {
        metaText = `${escapeHtml(cert.penerbit)} - ${escapeHtml(cert.tahun)}`;
      } else if (cert.penerbit) {
        metaText = escapeHtml(cert.penerbit);
      } else if (cert.tahun) {
        metaText = escapeHtml(cert.tahun);
      }

      card.innerHTML = `
        <div class="cert-img-wrap" style="position:relative;">
          ${imgHtml}
          ${fallbackDiv}
        </div>
        <div class="cert-info">
          <div class="cert-name font-heading">${escapeHtml(cert.nama)}</div>
          ${metaText ? `<div class="cert-meta text-muted font-mono text-xs">${metaText}</div>` : ''}
          ${buttonHtml}
        </div>
      `;

      const btn = card.querySelector('.btn-transkrip');
      if (btn && cert.imgBelakang) {
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          const fullImg = this.getAttribute('data-fullimg');
          if (fullImg) openModal(fullImg, this);
        });
      }

      container.appendChild(card);
    });
  }

  async function fetchCertificates(forceRefresh = false) {
    if (!forceRefresh) {
      try {
        const cached = localStorage.getItem(CACHE_KEY);
        const cachedTime = localStorage.getItem(CACHE_TIME_KEY);
        if (cached && cachedTime) {
          const now = Date.now();
          if (now - parseInt(cachedTime, 10) < CACHE_DURATION_MS) {
            renderCertificates(JSON.parse(cached));
            const remainingMins = Math.round((CACHE_DURATION_MS - (now - parseInt(cachedTime, 10))) / 60000);
            updateCacheStatusText(`Status: Data dari Cache (${remainingMins}m tersisa)`);
            return;
          }
        }
      } catch (e) {
        console.warn('Gagal membaca cache:', e);
      }
    }

    updateCacheStatusText('Status: Mengambil dari Google Sheets...');
    if (refreshBtn) refreshBtn.classList.add('loading');

    try {
      const response = await fetch(DATA_URL);
      if (!response.ok) throw new Error('Gagal mengakses spreadsheet');
      const rawText = await response.text();
      const jsonMatch = rawText.match(/google\.visualization\.Query\.setResponse\(([\s\S]*?)\);/);
      if (!jsonMatch) throw new Error('Respons JSON tidak valid');
      const data = JSON.parse(jsonMatch[1]);
      const rows = data.table.rows || [];

      const certificatesData = rows.map(row => {
        return {
          id: row.c[0] ? String(row.c[0].v) : '',
          timestamp: row.c[1] ? String(row.c[1].v) : '',
          nama: row.c[2] ? String(row.c[2].v) : 'Sertifikat',
          penerbit: row.c[3] ? String(row.c[3].v) : '',
          tahun: row.c[4] ? String(row.c[4].v) : '',
          tipe: row.c[5] ? String(row.c[5].v).toLowerCase() : 'horizontal',
          tombolAda: (row.c[6] ? String(row.c[6].v) : '') === 'ada',
          imgDepan: row.c[7] ? String(row.c[7].v) : '',
          imgBelakang: row.c[8] ? String(row.c[8].v) : ''
        }).filter(cert => cert.imgDepan !== '');

      try {
        localStorage.setItem(CACHE_KEY, JSON.stringify(certificatesData));
        localStorage.setItem(CACHE_TIME_KEY, Date.now().toString());
      } catch (e) {}

      renderCertificates(certificatesData);
      updateCacheStatusText('Status: Pembaruan Live Berhasil (Cache 1 Jam)');
    } catch (err) {
      console.error(err);
      try {
        const cached = localStorage.getItem(CACHE_KEY);
        if (cached) {
          renderCertificates(JSON.parse(cached));
          updateCacheStatusText('Status: Offline (Menampilkan Cache Terakhir)');
          if (refreshBtn) refreshBtn.classList.remove('loading');
          return;
        }
      } catch (e) {}

      // Fallback Data Terverifikasi
      const fallbackData = [
        { id: "1", nama: "Juara I LKS IT Network System Administration — Tingkat Kabupaten Purworejo", penerbit: "Dinas Pendidikan dan Kebudayaan", tahun: "2026", tipe: "horizontal", tombolAda: false, imgDepan: "/assets/certificates/sertifikat-lks.webp", imgBelakang: "" },
        { id: "2", nama: "Sertifikat Praktik Kerja Lapangan (PKL) — UPTD BLK Kebumen", penerbit: "UPTD BLK Kebumen", tahun: "2025", tipe: "horizontal", tombolAda: true, imgDepan: "/assets/certificates/blk-depan.webp", imgBelakang: "/assets/certificates/blk-mata-latihan.webp" },
        { id: "3", nama: "Sertifikat Praktik Kerja Lapangan (PKL) — IMC Computer", penerbit: "IMC Computer (Izzan Mediatek)", tahun: "2025", tipe: "horizontal", tombolAda: true, imgDepan: "/assets/certificates/imc-depan.webp", imgBelakang: "/assets/certificates/imc-transkrip.webp" }
      ];
      renderCertificates(fallbackData);
      updateCacheStatusText('Status: Offline (Menampilkan Data Fallback)');
    } finally {
      if (refreshBtn) refreshBtn.classList.remove('loading');
    }
  }

  if (refreshBtn) refreshBtn.addEventListener('click', () => fetchCertificates(true));

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => fetchCertificates(false));
  } else {
    fetchCertificates(false);
  }
})();
</script>

<style>
  .section-header { text-align: center; max-width: 800px; margin: 0 auto 36px; }
  .section-subtitle { font-size: 1.1rem; margin-top: 12px; }

  .btn-refresh {
    padding: 6px 14px;
    border-radius: 20px;
    background: var(--bg-surface);
    border: 1px solid var(--color-border);
    color: var(--color-foreground);
    transition: all 0.2s ease;
  }
  .btn-refresh:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .btn-refresh.loading .refresh-icon { animation: spin 1s linear infinite; }
  @keyframes spin { 100% { transform: rotate(360deg); } }

  /* Certificates Grid */
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 32px;
  }

  .cert-card {
    border-radius: 22px;
    background: var(--bg-card);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .cert-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-lg);
  }
  .featured-cert {
    border: 2px solid var(--color-primary);
    background: linear-gradient(180deg, var(--bg-card) 0%, rgba(255, 179, 0, 0.04) 100%);
  }

  .cert-img-wrap {
    width: 100%;
    height: 220px;
    overflow: hidden;
    background: var(--bg-surface);
  }
  .pkl-vertical .cert-img-wrap {
    height: 380px;
  }
  .cert-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s ease;
  }
  .cert-card:hover .cert-img-wrap img {
    transform: scale(1.05);
  }

  .cert-info {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 10px;
  }

  .cert-name {
    font-size: 1.25rem;
    line-height: 1.35;
    color: var(--color-foreground);
  }

  /* Modal */
  .modal {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .modal.show { display: flex; }
  .modal-backdrop {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
  }
  .modal-dialog {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    max-width: 900px;
    width: 100%;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    z-index: 2;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }
  .modal-header {
    padding: 16px 24px;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .close-modal {
    font-size: 1.75rem;
    line-height: 1;
    color: var(--color-muted);
    cursor: pointer;
    background: none;
    border: none;
    padding: 0 8px;
  }
  .close-modal:hover { color: var(--color-primary); }
  .modal-body {
    padding: 24px;
    overflow-y: auto;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .modal-content {
    max-width: 100%;
    max-height: 75vh;
    object-fit: contain;
    border-radius: 12px;
  }
</style>
