---
---

<section class="experience-showcase container section-py">
  <div class="section-header">
    <div class="section-badge">
      <span class="badge font-mono" data-i18n="nav.experience">Pengalaman</span>
    </div>
    <h2 class="font-heading" data-i18n="exp.title">Professional Experience &amp; Internship</h2>
    <p class="section-subtitle" data-i18n="exp.subtitle">
      Perjalanan Praktik Kerja Lapangan (PKL) dalam mengimplementasikan infrastruktur jaringan FTTH, administrasi server Linux/Debian, serta troubleshooting hardware &amp; jaringan.
    </p>
  </div>

  <!-- Timeline / Grid Pengalaman (Exact Match with experience.astro) -->
  <div class="experience-grid" aria-label="Daftar Pengalaman Kerja dan Magang">
    <!-- 1. UPTD BLK Kebumen -->
    <article class="experience-card glass-card">
      <div class="exp-header">
        <div class="company-wrap">
          <span class="company-badge font-mono">Network &amp; Server</span>
          <h3 class="experience-company font-heading" data-i18n="exp.card1.company">UPTD Balai Latihan Kerja (BLK) Kebumen</h3>
        </div>
        <span class="experience-date font-mono" data-i18n="exp.card1.date">Nov 2025 — Des 2025</span>
      </div>
      <div class="experience-role font-mono" data-i18n="exp.card1.role">Peserta Praktik Kerja Lapangan (Network &amp; Server)</div>
      <div class="divider-sub"></div>
      <ul class="experience-desc">
        <li data-i18n="exp.card1.desc1">Konfigurasi jaringan LAN, WLAN, dan Hotspot menggunakan MikroTik RouterOS.</li>
        <li data-i18n="exp.card1.desc2">Implementasi static routing menggunakan Cisco Packet Tracer.</li>
        <li data-i18n="exp.card1.desc3">Instalasi Debian 12 pada VMware dan konfigurasi web server lokal (Nginx).</li>
        <li data-i18n="exp.card1.desc4">Implementasi firewall MikroTik serta deployment CMS PrestaShop pada server lokal.</li>
      </ul>
      <div class="exp-footer mt-auto pt-4 flex flex-wrap gap-2">
        <span class="badge text-xs font-mono">MikroTik RouterOS</span>
        <span class="badge text-xs font-mono">Debian 12</span>
        <span class="badge text-xs font-mono">Cisco PT</span>
        <span class="badge text-xs font-mono">Nginx Web Server</span>
      </div>
    </article>

    <!-- 2. Fazza Computer -->
    <article class="experience-card glass-card">
      <div class="exp-header">
        <div class="company-wrap">
          <span class="company-badge font-mono">FTTH &amp; ISP Network</span>
          <h3 class="experience-company font-heading" data-i18n="exp.card2.company">Fazza Computer</h3>
        </div>
        <span class="experience-date font-mono" data-i18n="exp.card2.date">Sep 2025 — Nov 2025</span>
      </div>
      <div class="experience-role font-mono" data-i18n="exp.card2.role">Peserta Praktik Kerja Lapangan (FTTH &amp; Network)</div>
      <div class="divider-sub"></div>
      <ul class="experience-desc">
        <li data-i18n="exp.card2.desc1">Instalasi jaringan Fiber To The Home (FTTH) untuk pelanggan baru.</li>
        <li data-i18n="exp.card2.desc2">Konfigurasi dasar dan pengujian perangkat Optical Network Terminal (ONT).</li>
        <li data-i18n="exp.card2.desc3">Troubleshooting dasar dan pemeliharaan perangkat jaringan pelanggan.</li>
      </ul>
      <div class="exp-footer mt-auto pt-4 flex flex-wrap gap-2">
        <span class="badge text-xs font-mono">FTTH Fiber Optic</span>
        <span class="badge text-xs font-mono">ONT Configuration</span>
        <span class="badge text-xs font-mono">Network Troubleshooting</span>
      </div>
    </article>

    <!-- 3. IMC Computer -->
    <article class="experience-card glass-card">
      <div class="exp-header">
        <div class="company-wrap">
          <span class="company-badge font-mono">PC &amp; Network Hardware</span>
          <h3 class="experience-company font-heading" data-i18n="exp.card3.company">IMC Computer (Izzan Mediatek Computindo)</h3>
        </div>
        <span class="experience-date font-mono" data-i18n="exp.card3.date">Feb 2025 — Apr 2025</span>
      </div>
      <div class="experience-role font-mono" data-i18n="exp.card3.role">Peserta Praktik Kerja Lapangan (PC &amp; Network)</div>
      <div class="divider-sub"></div>
      <ul class="experience-desc">
        <li data-i18n="exp.card3.desc1">Instalasi sistem operasi Windows pada komputer dan laptop.</li>
        <li data-i18n="exp.card3.desc2">Perakitan komputer serta pemeriksaan fungsi hardware dan software.</li>
        <li data-i18n="exp.card3.desc3">Troubleshooting dasar dan pemeliharaan perangkat komputer.</li>
      </ul>
      <div class="exp-footer mt-auto pt-4 flex flex-wrap gap-2">
        <span class="badge text-xs font-mono">PC Assembly</span>
        <span class="badge text-xs font-mono">Windows OS Installation</span>
        <span class="badge text-xs font-mono">Hardware Diagnostics</span>
      </div>
    </article>
  </div>

  <div class="text-center exp-more-wrapper">
    <a href="/experience" class="btn-secondary inline-flex items-center gap-2" data-i18n="home.exp.more">
      Lihat Detail Semua Pengalaman →
    </a>
  </div>
</section>

<style>
  .section-header { text-align: center; max-width: 800px; margin: 0 auto 48px; }
  .section-badge { margin-bottom: 16px; }
  .section-subtitle { font-size: 1.1rem; margin-top: 16px; margin-bottom: 24px; color: var(--color-muted); }

  .exp-more-wrapper {
    margin-top: 52px;
  }

  .experience-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 32px;
  }

  .experience-card {
    padding: 32px;
    border-radius: 22px;
    background: var(--bg-card);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .experience-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-lg);
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 4px;
  }

  .company-wrap {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .company-badge {
    font-size: 0.75rem;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .experience-company {
    font-size: 1.35rem;
    line-height: 1.3;
    color: var(--color-foreground);
    margin-top: 0;
    margin-bottom: 0;
  }

  .experience-date {
    font-size: 0.88rem;
    color: var(--color-muted);
    background: var(--bg-surface);
    padding: 6px 12px;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    white-space: nowrap;
  }

  .experience-role {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 4px;
    margin-bottom: 6px;
  }

  .divider-sub {
    height: 1px;
    background: var(--color-border);
    margin: 8px 0;
  }

  .experience-desc {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.65;
    margin-top: 8px;
    margin-bottom: 16px;
    padding-left: 0;
  }

  .experience-desc li {
    position: relative;
    padding-left: 20px;
  }

  .experience-desc li::before {
    content: '▹';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .experience-grid { grid-template-columns: 1fr; }
    .experience-card { padding: 24px; }
  }
</style>
