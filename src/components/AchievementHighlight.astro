---
---

<section class="achievement-highlight container section-py">
  <div class="achievement-glass glass-card">
    <div class="achievement-image-wrap">
      <img id="ach-img" src="https://cdn.fatahmr.my.id/portfolio/assets/certificates/LKS-Certificate.webp" alt="Sertifikat Juara 1 LKS IT Network System Administration" loading="lazy" />
      <div class="achievement-badge-float">
        <span class="badge badge-gold font-mono" data-i18n="home.achievement.badge1">Top Achievement</span>
      </div>
    </div>
    
    <div class="achievement-content">
      <div class="badge-wrapper mb-3">
        <span class="badge badge-primary font-mono text-xs uppercase tracking-wider" data-i18n="home.achievement.badge2">Pencapaian Terbesar</span>
      </div>
      <h2 id="ach-title" class="font-heading achievement-title">
        Juara I - IT Network System Administration
      </h2>
      <p id="ach-desc" class="text-muted achievement-desc" data-i18n="home.achievement.desc">
        Pencapaian terbesar saya di tahun 2026. Meraih medali emas pada Lomba Kompetensi Siswa (LKS) tingkat Kabupaten dalam bidang lomba <strong>IT Network System Administration</strong>. Membuktikan kompetensi tingkat lanjut dalam membangun dan mengamankan infrastruktur jaringan yang kompleks.
      </p>
      
      <div class="achievement-meta">
        <div class="meta-item">
          <span class="meta-label" data-i18n="home.achievement.org">Penyelenggara:</span>
          <span id="ach-publisher" class="meta-value">LKS SMK Kabupaten Purworejo</span>
        </div>
      </div>

      <a href="/certificates" class="btn-primary mt-6 inline-flex" data-i18n="home.achievement.btn">
        Lihat Semua Sertifikat →
      </a>
    </div>
  </div>
</section>

<script is:inline>
(function() {
  const SPREADSHEET_ID = '1GtKyr8LGv5AfSChzfP7t6_4D0rBUoC8VeRdC_Rw6eqY';
  const SHEET_NAME = 'Sheet1';
  const DATA_URL = `https://docs.google.com/spreadsheets/d/${SPREADSHEET_ID}/gviz/tq?tqx=out:json&sheet=${SHEET_NAME}`;
  const CACHE_KEY = 'portfolio_certificates_cache_v2';
  
  async function loadTopAchievement() {
    try {
      let data = null;
      const cached = localStorage.getItem(CACHE_KEY);
      if (cached) {
        data = JSON.parse(cached);
      } else {
        const response = await fetch(DATA_URL);
        if (response.ok) {
          const rawText = await response.text();
          const jsonMatch = rawText.match(/google\.visualization\.Query\.setResponse\(([\s\S]*?)\);/);
          if (jsonMatch) {
            const parsed = JSON.parse(jsonMatch[1]);
            const rows = parsed.table.rows || [];
            data = rows.map(row => ({
              id: row.c[0] ? String(row.c[0].v) : '',
              nama: row.c[2] ? String(row.c[2].v) : 'Sertifikat',
              penerbit: row.c[3] ? String(row.c[3].v) : '',
              imgDepan: row.c[7] ? String(row.c[7].v) : ''
            }));
            localStorage.setItem(CACHE_KEY, JSON.stringify(data));
          }
        }
      }
      
      if (data && data.length > 0) {
        // Ambil sertifikat baris pertama (urutan pertama)
        const topCert = data[0];
        
        if (topCert.imgDepan) document.getElementById('ach-img').src = topCert.imgDepan;
        if (topCert.nama) document.getElementById('ach-title').textContent = topCert.nama;
        if (topCert.penerbit) document.getElementById('ach-publisher').textContent = topCert.penerbit;
      }
    } catch (e) {
      console.warn('Failed loading top achievement:', e);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadTopAchievement);
  } else {
    loadTopAchievement();
  }
})();
</script>

<style>
  .achievement-highlight {
    margin-bottom: 2rem;
  }

  .achievement-glass {
    border-radius: 1.25rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-color: var(--color-accent);
    box-shadow: 0 0 25px rgba(245, 158, 11, 0.08);
  }

  .achievement-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .achievement-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  
  .achievement-glass:hover .achievement-image-wrap img {
    transform: scale(1.02);
  }

  .achievement-badge-float {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 10;
  }

  .achievement-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .achievement-title {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: var(--color-foreground);
    line-height: 1.3;
  }

  .achievement-desc {
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .achievement-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .meta-item {
    font-size: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .meta-label {
    color: var(--color-muted);
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .meta-value {
    color: var(--color-foreground);
    font-weight: 500;
  }

  /* Badge Gold Khusus */
  .badge-gold {
    background-color: rgba(245, 158, 11, 0.15);
    color: var(--color-accent);
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  @media (min-width: 768px) {
    .achievement-glass {
      flex-direction: row;
    }
    
    .achievement-image-wrap {
      width: 50%;
      border-bottom: none;
      border-right: 1px solid var(--color-border);
    }
    
    .achievement-content {
      width: 50%;
      padding: 3rem;
      align-items: flex-start;
      text-align: left;
    }
    
    .achievement-meta {
      flex-direction: row;
      gap: 2rem;
    }
  }
</style>
