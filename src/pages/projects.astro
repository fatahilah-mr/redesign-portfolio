---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Projects & Lab Archive" description="Portofolio proyek IT Network & System Administration oleh Fatahilah Miftahul Rahman, termasuk rancang bangun jaringan Cisco Packet Tracer dan setup MikroTik Gateway.">
  <section class="projects-section container section-py">
    <div class="section-header">
      <div class="section-badge">
        <span class="badge font-mono" data-i18n="nav.projects">Proyek & Lab</span>
      </div>
      <h1 class="font-heading" data-i18n="proj.title">Portofolio Proyek & Lab Archive</h1>
      <p class="section-subtitle">
        Implementasi rancang bangun topologi jaringan, pengamanan sistem server, dan eksperimen lab di lingkungan Cisco Packet Tracer, MikroTik, dan Linux Server.
      </p>
    </div>

    <!-- CMS Status Bar -->
    <div class="cms-status-bar font-mono text-sm" id="proj-cms-status" aria-live="polite">
      <span class="spinner"></span> <span>Memeriksa pembaruan proyek dari Google Sheets CMS...</span>
    </div>

    <!-- Projects Grid (Static verified from ~/storage/shared/portofolio + Dynamic Sheets) -->
    <div class="projects-grid" id="projects-grid-container" aria-label="Daftar Proyek">
      <!-- Populated by client script with verified fallback & cached CMS -->
    </div>

    <!-- Action Buttons -->
    <div class="projects-footer-actions">
      <a href="https://github.com/fatahilah-mr" target="_blank" rel="noopener noreferrer" class="btn-primary">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        Kunjungi Repositori GitHub
      </a>
      <button class="btn-secondary" id="refresh-proj-btn" title="Segarkan Cache Proyek CMS">
        ↻ Segarkan Data Proyek
      </button>
    </div>
  </section>

  <!-- Project Detail Accessible Dialog -->
  <dialog id="project-modal" class="project-modal glass-card" aria-labelledby="proj-modal-title">
    <div class="modal-header">
      <span class="badge badge-primary font-mono">📁 Detail Proyek IT Network</span>
      <button class="close-modal-btn" id="close-proj-modal" aria-label="Tutup Detail Proyek">✕</button>
    </div>
    <div class="modal-body">
      <div class="modal-img-wrap mb-6">
        <img id="proj-modal-img" src="" alt="Topologi Proyek" loading="lazy" class="proj-detail-img" />
      </div>
      <h2 id="proj-modal-title" class="font-heading text-2xl mb-3">Judul Proyek</h2>
      <p id="proj-modal-desc" class="text-muted leading-relaxed mb-6">Deskripsi lengkap proyek.</p>
      <div class="modal-footer flex justify-end gap-3">
        <button id="close-proj-modal-btn" class="btn-secondary">Tutup (Escape / Enter)</button>
      </div>
    </div>
  </dialog>
</Layout>

<style>
  .section-header { text-align: center; max-width: 800px; margin: 0 auto 36px; }
  .section-badge { margin-bottom: 16px; }
  .section-subtitle { font-size: 1.1rem; margin-top: 12px; }

  .cms-status-bar {
    text-align: center;
    color: var(--color-muted);
    margin-bottom: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px 20px;
    background: var(--bg-surface);
    border-radius: 12px;
    border: 1px solid var(--color-border);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
    gap: 36px;
    margin-bottom: 56px;
  }

  .project-card {
    border-radius: 20px;
    background: var(--bg-card);
    border: 1px solid var(--color-border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    cursor: pointer;
  }

  .project-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-lg);
  }

  .project-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--bg-surface);
    overflow: hidden;
    position: relative;
  }

  .project-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .project-card:hover .project-img-wrap img {
    transform: scale(1.05);
  }

  .project-info {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex-grow: 1;
  }

  .project-card-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.5rem;
    line-height: 1.35;
    color: var(--color-foreground);
  }

  .project-desc {
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .projects-footer-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }

  /* Modal */
  .project-modal {
    margin: auto;
    padding: 32px;
    max-width: 800px;
    width: 92%;
    border-radius: 22px;
    background: var(--bg-card);
    color: var(--color-foreground);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
    z-index: 3000;
  }

  .project-modal::backdrop {
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(10px);
  }

  .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .close-modal-btn { background: none; border: none; font-size: 1.5rem; color: var(--color-muted); cursor: pointer; }
  .close-modal-btn:hover { color: var(--color-foreground); }

  .modal-img-wrap {
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-surface);
    border: 1px solid var(--color-border);
    max-height: 480px;
  }

  .proj-detail-img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .projects-grid { grid-template-columns: 1fr; }
    .project-modal { padding: 20px; }
  }
</style>

<script is:inline>
  // ==================================================
  // GOOGLE SHEETS CMS FOR PROJECTS & EXACT SOURCE VERIFIED
  // ==================================================
  const PROJ_SPREADSHEET_ID = '1GtKyr8LGv5AfSChzfP7t6_4D0rBUoC8VeRdC_Rw6eqY';
  const PROJ_SHEET_NAME = 'Sheet2'; // Sheet untuk projects jika ada
  const PROJ_DATA_URL = `https://docs.google.com/spreadsheets/d/${PROJ_SPREADSHEET_ID}/gviz/tq?tqx=out:json&sheet=${PROJ_SHEET_NAME}`;

  const PROJ_CACHE_KEY = 'fatahilah_projects_cache_v2';
  const PROJ_CACHE_TIME_KEY = 'fatahilah_projects_cache_time_v2';
  const PROJ_CACHE_DURATION = 3600000; // 1 Jam dalam milidetik

  let lastProjFocused = null;

  // Exact verified projects from ~/storage/shared/portofolio/index.html
  const EXACT_PROJECTS = [
    {
      id: "1",
      title: "Rancang Bangun Jaringan Kantor 3 Lantai",
      desc: "Mendesain infrastruktur jaringan kantor 3 lantai menggunakan Cisco Packet Tracer. Proyek ini menerapkan segmentasi VLAN terpisah untuk setiap lantai, manajemen alokasi IP otomatis via DHCP Server, integrasi lokal DNS Server, serta konfigurasi satu router management khusus untuk kendali penuh administrator.",
      image: "/assets/Topologi-Cisco-PT-01.webp",
      tags: ["Cisco Packet Tracer", "VLAN", "DHCP Server", "Network Architecture"]
    },
    {
      id: "2",
      title: "Setup Gateway & Keamanan Jaringan MikroTik",
      desc: "Membangun jaringan gateway fungsional pada RouterBoard MikroTik lewat Winbox. Konfigurasi mencakup setup IPv4 address, aktivasi dan manajemen WLAN interface untuk akses wireless, implementasi Firewall NAT agar jaringan lokal terhubung ke internet, konfigurasi DNS dan DHCP Server, serta pengujian stabilitas koneksi via terminal.",
      image: "/assets/Mikrotik-01.webp",
      tags: ["MikroTik RouterBoard", "Winbox", "NAT Firewall", "WLAN Gateway"]
    }
  ];

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>'"]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      if (m === "'") return '&#039;';
      if (m === '"') return '&quot;';
      return m;
    });
  }

  function openProjectModal(project, triggerElement) {
    lastProjFocused = triggerElement;
    const modal = document.getElementById('project-modal');
    const img = document.getElementById('proj-modal-img');
    const title = document.getElementById('proj-modal-title');
    const desc = document.getElementById('proj-modal-desc');
    const closeBtn = document.getElementById('close-proj-modal');

    if (modal && img && title && desc) {
      img.src = project.image;
      img.alt = project.title;
      title.textContent = project.title;
      desc.textContent = project.desc;
      modal.showModal();
      closeBtn?.focus();
    }
  }

  function setupProjModalListeners() {
    const modal = document.getElementById('project-modal');
    const c1 = document.getElementById('close-proj-modal');
    const c2 = document.getElementById('close-proj-modal-btn');
    if (!modal) return;

    const closeHandler = () => {
      modal.close();
      if (lastProjFocused) lastProjFocused.focus();
    };

    c1?.addEventListener('click', closeHandler);
    c2?.addEventListener('click', closeHandler);

    modal.addEventListener('click', (e) => {
      const rect = modal.getBoundingClientRect();
      const isInDialog = (rect.top <= e.clientY && e.clientY <= rect.top + rect.height &&
        rect.left <= e.clientX && e.clientX <= rect.left + rect.width);
      if (!isInDialog) closeHandler();
    });
  }

  function renderProjects(projectsList) {
    const container = document.getElementById('projects-grid-container');
    if (!container) return;

    container.innerHTML = '';
    projectsList.forEach(proj => {
      const card = document.createElement('div');
      card.className = 'project-card glass-card';
      card.setAttribute('tabindex', '0');
      card.setAttribute('role', 'article');
      card.setAttribute('aria-label', proj.title);

      const tagsHtml = (proj.tags || []).map(t => `<span class="badge font-mono text-xs">${escapeHtml(t)}</span>`).join('');

      card.innerHTML = `
        <div class="project-img-wrap">
          <img src="${proj.image}" alt="${escapeHtml(proj.title)}" loading="lazy" />
        </div>
        <div class="project-info">
          <h3 class="project-card-title">${escapeHtml(proj.title)}</h3>
          <p class="project-desc">${escapeHtml(proj.desc)}</p>
          <div class="flex flex-wrap gap-2 mt-auto pt-4 border-t border-border">
            ${tagsHtml}
          </div>
        </div>
      `;

      card.addEventListener('click', () => openProjectModal(proj, card));
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openProjectModal(proj, card);
        }
      });

      container.appendChild(card);
    });
  }

  async function fetchProjects(forceRefresh = false) {
    const statusEl = document.getElementById('proj-cms-status');

    if (!forceRefresh) {
      try {
        const cachedTime = localStorage.getItem(PROJ_CACHE_TIME_KEY);
        const cachedData = localStorage.getItem(PROJ_CACHE_KEY);
        if (cachedTime && cachedData && (Date.now() - Number(cachedTime) < PROJ_CACHE_DURATION)) {
          const parsed = JSON.parse(cachedData);
          renderProjects(parsed);
          if (statusEl) statusEl.innerHTML = `✅ Menampilkan proyek dari cache lokal (Diperbarui dalam 1 jam terakhir)`;
          return;
        }
      } catch (e) {
        console.warn('Projects cache read error:', e);
      }
    }

    if (statusEl && forceRefresh) statusEl.innerHTML = `<span class="spinner"></span> <span>Mengambil data proyek terbaru dari Google Sheets API...</span>`;

    try {
      const response = await fetch(PROJ_DATA_URL, { signal: AbortSignal.timeout(6000) });
      if (!response.ok) throw new Error('Spreadsheet not ok');
      const rawText = await response.text();
      const jsonMatch = rawText.match(/google\.visualization\.Query\.setResponse\(([\s\S]*?)\);/);
      if (!jsonMatch) throw new Error('No json match');
      const data = JSON.parse(jsonMatch[1]);
      const rows = data.table?.rows || [];

      if (rows.length > 0) {
        const dynamicProjects = rows.map(row => ({
          id: row.c[0] ? String(row.c[0].v) : '',
          title: row.c[1] ? String(row.c[1].v) : '',
          desc: row.c[2] ? String(row.c[2].v) : '',
          image: row.c[3] ? String(row.c[3].v) : '',
          tags: (row.c[4] ? String(row.c[4].v) : '').split(',').map(s => s.trim()).filter(Boolean)
        })).filter(p => p.title && p.image);

        if (dynamicProjects.length > 0) {
          renderProjects(dynamicProjects);
          localStorage.setItem(PROJ_CACHE_KEY, JSON.stringify(dynamicProjects));
          localStorage.setItem(PROJ_CACHE_TIME_KEY, String(Date.now()));
          if (statusEl) statusEl.innerHTML = `✅ Proyek berhasil diperbarui dari Google Sheets CMS`;
          return;
        }
      }
      throw new Error('Fallback needed');
    } catch (err) {
      console.warn('Using verified exact projects source:', err);
      renderProjects(EXACT_PROJECTS);
      if (statusEl) statusEl.innerHTML = `⚡ Menampilkan portofolio proyek terverifikasi (Offline / Fallback Ready)`;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    setupProjModalListeners();
    fetchProjects(false);

    const refreshBtn = document.getElementById('refresh-proj-btn');
    if (refreshBtn) {
      refreshBtn.addEventListener('click', () => fetchProjects(true));
    }
  });
</script>
