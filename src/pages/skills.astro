---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Keahlian & Kompetensi" description="Keahlian Teknis Fatahilah: Network Admin, Server Management, AI Prompt Engineering, dan Web Development">
  <section class="skills-section container section-py">
    <div class="section-header">
      <div class="section-badge">
        <span class="badge font-mono" data-i18n="nav.skills">Keahlian</span>
      </div>
      <h1 class="font-heading" data-i18n="skills.title">Keahlian & Kompetensi Teknis</h1>
      <p class="section-subtitle">Empat pilar keahlian utama yang menggabungkan infrastruktur server, jaringan, otomatisasi AI, dan pengembangan web modern.</p>
    </div>

    <!-- Skills Grid -->
    <div class="skills-grid">
      <!-- Category 1: Network Admin -->
      <div class="skill-card glass-card">
        <div class="card-header">
          <div class="icon-circle icon-blue">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>
          </div>
          <h2 class="skill-cat-title font-heading" data-i18n="skills.cat1.title">1. Network Administration</h2>
        </div>
        <p class="skill-cat-desc" data-i18n="skills.cat1.desc">
          Routing, Switching, VLAN, BGP/OSPF, Cisco IOS, Mikrotik RouterOS, Network Troubleshooting & Firewall Rules.
        </p>
        <div class="tags-cluster font-mono">
          <span class="tag">Cisco IOS</span>
          <span class="tag">Mikrotik RouterOS</span>
          <span class="tag">VLAN / Trunking</span>
          <span class="tag">OSPF & BGP</span>
          <span class="tag">Firewall Mangle</span>
          <span class="tag">Subnetting</span>
        </div>
      </div>

      <!-- Category 2: System & Server -->
      <div class="skill-card glass-card">
        <div class="card-header">
          <div class="icon-circle icon-indigo">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="8" x="2" y="2" rx="2"/><rect width="20" height="8" x="2" y="14" rx="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>
          </div>
          <h2 class="skill-cat-title font-heading" data-i18n="skills.cat2.title">2. System & Server Management</h2>
        </div>
        <p class="skill-cat-desc" data-i18n="skills.cat2.desc">
          Linux (Debian/Ubuntu/CentOS), Windows Server, DNS, DHCP, Web Server (Apache/Nginx), Docker & Virtualisasi.
        </p>
        <div class="tags-cluster font-mono">
          <span class="tag">Debian / Ubuntu</span>
          <span class="tag">Windows Server</span>
          <span class="tag">Apache / Nginx</span>
          <span class="tag">DNS Bind9</span>
          <span class="tag">Docker Container</span>
          <span class="tag">Proxmox / KVM</span>
        </div>
      </div>

      <!-- Category 3: AI Prompt & Automation -->
      <div class="skill-card glass-card">
        <div class="card-header">
          <div class="icon-circle icon-cyan">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2v8"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m16 6-4 4-4-4"/><path d="M16 18a4 4 0 0 0-8 0"/></svg>
          </div>
          <h2 class="skill-cat-title font-heading" data-i18n="skills.cat3.title">3. AI Prompt Engineering & Automation</h2>
        </div>
        <p class="skill-cat-desc" data-i18n="skills.cat3.desc">
          LLM Prompt Design, System Prompts, Chain-of-Thought (CoT), Automated Diagnostics, AI-Assisted Shell Scripting.
        </p>
        <div class="tags-cluster font-mono">
          <span class="tag">System Prompting</span>
          <span class="tag">Chain-of-Thought</span>
          <span class="tag">Shell Automation</span>
          <span class="tag">AI Network Diagnostics</span>
          <span class="tag">Structured JSON Output</span>
        </div>
      </div>

      <!-- Category 4: Web Development & CMS (NEW CATEGORY) -->
      <div class="skill-card glass-card">
        <div class="card-header">
          <div class="icon-circle icon-gold">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h2 class="skill-cat-title font-heading" data-i18n="skills.cat4.title">4. Web Development & CMS</h2>
        </div>
        <p class="skill-cat-desc" data-i18n="skills.cat4.desc">
          HTML5, Vanilla CSS, JavaScript, Astro Framework, Git Version Control, Integrasi Google Sheets Headless CMS.
        </p>
        <div class="tags-cluster font-mono">
          <span class="tag">Astro MPA v5</span>
          <span class="tag">Vanilla CSS Design</span>
          <span class="tag">Google Sheets CMS</span>
          <span class="tag">Git & GitHub</span>
          <span class="tag">WCAG AA A11Y</span>
          <span class="tag">Cloudflare / Vercel</span>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 56px;
  }

  .section-badge {
    margin-bottom: 16px;
  }

  .section-subtitle {
    font-size: 1.1rem;
    margin-top: 12px;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 32px;
  }

  .skill-card {
    padding: 36px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .icon-circle {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-blue { background: rgba(59, 130, 246, 0.15); color: var(--color-primary); }
  .icon-indigo { background: rgba(99, 102, 241, 0.15); color: var(--color-secondary); }
  .icon-cyan { background: rgba(6, 182, 212, 0.15); color: var(--color-cyan); }
  .icon-gold { background: rgba(245, 158, 11, 0.15); color: var(--color-accent); }

  .skill-cat-title {
    font-size: 1.4rem;
  }

  .skill-cat-desc {
    font-size: 1.02rem;
    line-height: 1.7;
    min-height: 64px;
  }

  .tags-cluster {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px dashed var(--color-border);
  }

  .tag {
    padding: 6px 14px;
    border-radius: 8px;
    background: var(--bg-surface);
    border: 1px solid var(--color-border);
    font-size: 0.825rem;
    font-weight: 500;
    color: var(--color-foreground);
    transition: all 0.2s ease;
  }

  .skill-card:hover .tag {
    border-color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
    .skill-card {
      padding: 24px;
    }
  }
</style>
