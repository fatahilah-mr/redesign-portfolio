---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Keahlian & Kompetensi" description="Keahlian Teknis Fatahilah: Network Admin, Server Management, AI Prompt Engineering, dan Web Development">
  <section class="skills-section container section-py">
    <div class="section-header">
      <div class="section-badge">
        <span class="badge font-mono" data-i18n="nav.skills">Keahlian</span>
      </div>
      <h1 class="font-heading" data-i18n="skills.title">Keahlian &amp; Kompetensi Teknis</h1>
      <p class="section-subtitle">Empat pilar keahlian utama yang mencakup Hardware &amp; Cabling, Cisco Networking, MikroTik &amp; Wireless, serta Server &amp; OS Administration.</p>
    </div>

    <!-- Skills Grid (Mengikuti acuan_dari_web_portofolio/index.html #skills) -->
    <div class="skills-grid">
      <!-- Category 1: Hardware & Cabling -->
      <div class="skill-card glass-card">
        <div class="card-header">
          <div class="icon-circle icon-blue">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 20V6a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v14"/><path d="M2 20h20"/><path d="M14 12v.01"/></svg>
          </div>
          <h2 class="skill-cat-title font-heading">Hardware &amp; Cabling</h2>
        </div>
        <ul class="skill-list space-y-2.5 text-muted leading-relaxed text-sm">
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>PC Assembly &amp; Hardware Troubleshooting</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>UTP Cabling (Crimping) &amp; LAN Testing</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Fiber Optic Splicing &amp; Fast Connector Termination</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Fiber Optic Testing (OPM &amp; VFL)</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Rack Server &amp; Cable Management</span></li>
        </ul>
        <div class="tags-cluster font-mono mt-auto pt-4 border-t border-border">
          <span class="tag">PC Assembly</span>
          <span class="tag">UTP Crimping</span>
          <span class="tag">Fiber Optic</span>
          <span class="tag">OPM &amp; VFL</span>
          <span class="tag">Rack Server</span>
        </div>
      </div>

      <!-- Category 2: Cisco Networking -->
      <div class="skill-card glass-card">
        <div class="card-header">
          <div class="icon-circle icon-indigo">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>
          </div>
          <h2 class="skill-cat-title font-heading">Cisco Networking</h2>
        </div>
        <ul class="skill-list space-y-2.5 text-muted leading-relaxed text-sm">
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Konfigurasi Dasar &amp; Keamanan Device</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Infrastruktur Switching, VLAN &amp; Trunking</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Implementasi STP Portfast &amp; EtherChannel</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Pengalamatan IPv4 &amp; IPv6 Addressing</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Static &amp; Dynamic Routing (OSPF, BGP, EIGRP, RIP)</span></li>
        </ul>
        <div class="tags-cluster font-mono mt-auto pt-4 border-t border-border">
          <span class="tag">Cisco IOS</span>
          <span class="tag">VLAN / Trunking</span>
          <span class="tag">STP &amp; EtherChannel</span>
          <span class="tag">IPv4 / IPv6</span>
          <span class="tag">OSPF / BGP / EIGRP</span>
        </div>
      </div>

      <!-- Category 3: Mikrotik & Wireless -->
      <div class="skill-card glass-card">
        <div class="card-header">
          <div class="icon-circle icon-cyan">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>
          </div>
          <h2 class="skill-cat-title font-heading">Mikrotik &amp; Wireless</h2>
        </div>
        <ul class="skill-list space-y-2.5 text-muted leading-relaxed text-sm">
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Konfigurasi Dasar, Pengalamatan IP &amp; Internet Gateway (Identity, IPv4, DHCP Client/Server, DNS, SNTP)</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Manajemen Pengguna &amp; Hak Akses Perangkat (User Privilege, Password Hardening, Custom Service Ports)</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Keamanan Jaringan &amp; Firewall (NAT Masquerade, Content &amp; Media Blocking, Port Forwarding)</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Wireless Network Setup (Mikrotik AP-Bridge Mode, Security Profiles, &amp; SOHO Wireless Router Configuration)</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Mikrotik Hotspot Gateway &amp; User Profile Management</span></li>
        </ul>
        <div class="tags-cluster font-mono mt-auto pt-4 border-t border-border">
          <span class="tag">RouterOS</span>
          <span class="tag">Firewall NAT</span>
          <span class="tag">AP-Bridge Mode</span>
          <span class="tag">Hotspot Gateway</span>
          <span class="tag">Bandwidth Mgmt</span>
        </div>
      </div>

      <!-- Category 4: Server & OS Administration -->
      <div class="skill-card glass-card">
        <div class="card-header">
          <div class="icon-circle icon-gold">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="8" x="2" y="2" rx="2"/><rect width="20" height="8" x="2" y="14" rx="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>
          </div>
          <h2 class="skill-cat-title font-heading">Server &amp; OS Administration</h2>
        </div>
        <ul class="skill-list space-y-2.5 text-muted leading-relaxed text-sm">
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Linux Server (Debian 12 &amp; 13): Network Config (IP, Gateway, DNS, Resolvconf, Timezone) &amp; SSH Server</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Linux Services (Debian 12 &amp; 13): DNS Server (Bind9) &amp; Web Server (Nginx, Apache2, Virtual Host)</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Network Optimization &amp; Security: DHCP Server, Nftables Firewall, &amp; VRRP Redundancy</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>High Availability Server: HAProxy (Load Balancing Round-Robin)</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Windows Server 2022 Services: ADDS, DNS Server, DHCP Server, &amp; IIS (Internet Information Services)</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>Windows Server Data Mgmt: File Sharing, RAID Storage, Organizational Units (OU), User &amp; Group Management</span></li>
          <li class="flex items-start gap-2"><span class="text-primary font-bold">•</span><span>AI Prompt Engineering: Pemanfaatan LLM untuk Otomatisasi Skrip &amp; Troubleshooting Sistem</span></li>
        </ul>
        <div class="tags-cluster font-mono mt-auto pt-4 border-t border-border">
          <span class="tag">Debian 12/13</span>
          <span class="tag">Bind9 &amp; Nginx</span>
          <span class="tag">HAProxy &amp; VRRP</span>
          <span class="tag">Windows Server 2022</span>
          <span class="tag">AI Prompt Engineering</span>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 56px;
  }

  .section-badge {
    margin-bottom: 16px;
  }

  .section-subtitle {
    font-size: 1.1rem;
    margin-top: 16px;
    margin-bottom: 24px;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 32px;
  }

  .skill-card {
    padding: 36px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 4px;
  }

  .icon-circle {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-blue { background: rgba(59, 130, 246, 0.15); color: var(--color-primary); }
  .icon-indigo { background: rgba(99, 102, 241, 0.15); color: var(--color-secondary); }
  .icon-cyan { background: rgba(6, 182, 212, 0.15); color: var(--color-cyan); }
  .icon-gold { background: rgba(245, 158, 11, 0.15); color: var(--color-accent); }

  .skill-cat-title {
    font-size: 1.4rem;
    margin-top: 0;
    margin-bottom: 0;
  }

  .skill-cat-desc {
    font-size: 1.02rem;
    line-height: 1.7;
    min-height: 64px;
    margin-top: 4px;
    margin-bottom: 16px;
  }

  .tags-cluster {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px dashed var(--color-border);
  }

  .tag {
    padding: 6px 14px;
    border-radius: 8px;
    background: var(--bg-surface);
    border: 1px solid var(--color-border);
    font-size: 0.825rem;
    font-weight: 500;
    color: var(--color-foreground);
    transition: all 0.2s ease;
  }

  .skill-card:hover .tag {
    border-color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
    .skill-card {
      padding: 24px;
    }
  }
</style>
