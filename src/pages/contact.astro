---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hubungi Saya" description="Tautan kontak resmi Fatahilah Miftahul Rahman: WhatsApp, LinkedIn, GitHub, Email, dan Unduh Curriculum Vitae (CV).">
  <section class="contact-section container section-py">
    <div class="section-header">
      <div class="section-badge">
        <span class="badge font-mono" data-i18n="nav.contact">Kontak</span>
      </div>
      <h1 class="font-heading" data-i18n="contact.title">Hubungi Saya & Saluran Resmi</h1>
      <p class="section-subtitle" data-i18n="contact.subtitle">
        Terbuka untuk kolaborasi proyek jaringan IT, magang, diskusi teknis sistem administrasi, maupun peluang karir profesional.
      </p>
    </div>

    <!-- Official Contact Grid (Exact Source from ~/storage/shared/portofolio) -->
    <div class="contact-grid">
      <!-- 1. WhatsApp -->
      <a href="https://wa.me/6285117470256" target="_blank" rel="noopener noreferrer" class="contact-card glass-card wa-theme">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.713-1.455L0 24zm6.59-4.846c1.642.973 3.298 1.485 4.93 1.486 5.532 0 10.033-4.505 10.036-10.042.002-2.684-1.038-5.207-2.93-7.101C16.34 1.599 13.82 1.554 11.14 1.554 5.607 1.554 1.105 6.058 1.102 11.595c-.001 1.748.469 3.454 1.359 4.96l-.982 3.59 3.68-.966zm13.107-5.597c-.36-.18-2.126-1.05-2.456-1.17-.33-.12-.57-.18-.81.18-.24.36-.93 1.17-1.14 1.41-.21.24-.42.27-.78.09-.36-.18-1.52-.56-2.894-1.784-1.07-.955-1.793-2.134-2.004-2.494-.21-.36-.02-.555.16-.735.16-.16.36-.42.54-.63.18-.21.24-.36.36-.6.12-.24.06-.45-.03-.63-.09-.18-.81-1.95-1.11-2.672-.293-.703-.592-.609-.81-.62-.21-.01-.45-.01-.69-.01-.24 0-.63.09-.96.45-.33.36-1.26 1.23-1.26 3l1.83 3.84c.18.36 3.54 5.401 8.58 7.581 1.2.519 2.139.83 2.872 1.062 1.203.381 2.297.328 3.162.2s1.926-.78 2.196-1.5c.27-.72.27-1.35.19-1.47-.08-.12-.3-.21-.66-.39z"/></svg>
        </div>
        <div class="contact-details">
          <span class="contact-label font-mono" data-i18n="contact.card.wa.label">Chat Langsung</span>
          <h3 class="contact-title font-heading">WhatsApp</h3>
          <p class="contact-val font-mono">+62 851-1747-0256</p>
        </div>
        <span class="action-arrow">↗</span>
      </a>

      <!-- 2. LinkedIn -->
      <a href="https://www.linkedin.com/in/fatahilah-mr" target="_blank" rel="noopener noreferrer" class="contact-card glass-card linkedin-theme">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </div>
        <div class="contact-details">
          <span class="contact-label font-mono" data-i18n="contact.card.ln.label">Jaringan Profesional</span>
          <h3 class="contact-title font-heading">LinkedIn</h3>
          <p class="contact-val font-mono">fatahilah-mr</p>
        </div>
        <span class="action-arrow">↗</span>
      </a>

      <!-- 3. GitHub -->
      <a href="https://github.com/fatahilah-mr" target="_blank" rel="noopener noreferrer" class="contact-card glass-card github-theme">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </div>
        <div class="contact-details">
          <span class="contact-label font-mono" data-i18n="contact.card.gh.label">Repositori & Kode</span>
          <h3 class="contact-title font-heading">GitHub</h3>
          <p class="contact-val font-mono">github.com/fatahilah-mr</p>
        </div>
        <span class="action-arrow">↗</span>
      </a>

      <!-- 4. Email -->
      <a href="mailto:fatahilah.f10@gmail.com" class="contact-card glass-card email-theme">
        <div class="contact-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </div>
        <div class="contact-details">
          <span class="contact-label font-mono" data-i18n="contact.card.mail.label">Surat Elektronik</span>
          <h3 class="contact-title font-heading" data-i18n="contact.card.mail.title">Email</h3>
          <p class="contact-val font-mono">fatahilah.f10@gmail.com</p>
        </div>
        <span class="action-arrow">✉</span>
      </a>

      <!-- 5. Download CV / Resume -->
      <a href="https://docs.google.com/viewer?url=https://cdn.fatahmr.my.id/portfolio/assets/CV%20Fatahilah%20Miftahul%20Rahman.pdf" target="_blank" rel="noopener noreferrer" class="contact-card glass-card cv-theme col-span-full">
        <div class="contact-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
        </div>
        <div class="contact-details">
          <span class="contact-label font-mono" data-i18n="contact.card.cv.label">Dokumen Resmi</span>
          <h3 class="contact-title font-heading" data-i18n="contact.card.cv.title">Download CV</h3>
          <p class="contact-val font-mono" data-i18n="contact.card.cv.val">Lihat &amp; Unduh Curriculum Vitae via Google Viewer</p>
        </div>
        <span class="action-arrow">⬇</span>
      </a>
    </div>

    <!-- Quick Form Box / CTA -->
    <div class="contact-banner glass-card mt-12 text-center">
      <h2 class="font-heading text-2xl mb-3" data-i18n="contact.banner.title">Butuh Respons Cepat?</h2>
      <p class="text-muted max-w-xl mx-auto mb-6" data-i18n="contact.banner.desc">
        Untuk keperluan urgensi tinggi atau penawaran kerja sama langsung, disarankan untuk menghubungi via WhatsApp atau LinkedIn agar pesan Anda segera saya terima.
      </p>
      <a href="https://wa.me/6285117470256" target="_blank" rel="noopener noreferrer" class="btn-primary" data-i18n="contact.banner.btn">
        Kirim Pesan WhatsApp Sekarang
      </a>
    </div>
  </section>
</Layout>

<style>
  .section-header { text-align: center; max-width: 800px; margin: 0 auto 48px; }
  .section-badge { margin-bottom: 16px; }
  .section-subtitle { font-size: 1.1rem; margin-top: 16px; margin-bottom: 24px; }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 28px;
    margin-bottom: 48px;
  }

  .col-span-full {
    grid-column: 1 / -1;
  }

  .contact-card {
    padding: 28px;
    border-radius: 20px;
    background: var(--bg-card);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 20px;
    text-decoration: none;
    color: var(--color-foreground);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .contact-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }

  .contact-icon {
    width: 60px;
    height: 60px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: var(--bg-surface);
    transition: transform 0.3s ease;
  }

  .contact-card:hover .contact-icon {
    transform: scale(1.1) rotate(-4deg);
  }

  /* Theme Accents */
  .wa-theme .contact-icon { color: #25D366; background: rgba(37, 211, 102, 0.12); border: 1px solid rgba(37, 211, 102, 0.3); }
  .wa-theme:hover { border-color: #25D366; }

  .linkedin-theme .contact-icon { color: #0A66C2; background: rgba(10, 102, 194, 0.12); border: 1px solid rgba(10, 102, 194, 0.3); }
  .linkedin-theme:hover { border-color: #0A66C2; }

  .github-theme .contact-icon { color: var(--color-foreground); background: var(--bg-surface); border: 1px solid var(--color-border); }
  .github-theme:hover { border-color: var(--color-foreground); }

  .email-theme .contact-icon { color: #EA4335; background: rgba(234, 67, 53, 0.12); border: 1px solid rgba(234, 67, 53, 0.3); }
  .email-theme:hover { border-color: #EA4335; }

  .cv-theme .contact-icon { color: var(--color-primary); background: rgba(0, 240, 255, 0.12); border: 1px solid rgba(0, 240, 255, 0.3); }
  .cv-theme:hover { border-color: var(--color-primary); }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex-grow: 1;
  }

  .contact-label {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-title {
    font-size: 1.35rem;
    line-height: 1.25;
    margin-top: 0;
    margin-bottom: 2px;
  }

  .contact-val {
    font-size: 0.9rem;
    color: var(--color-muted);
    word-break: break-all;
  }

  .action-arrow {
    font-size: 1.5rem;
    color: var(--color-muted);
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .contact-card:hover .action-arrow {
    transform: translate(3px, -3px);
    color: var(--color-primary);
  }

  .contact-banner {
    padding: 44px 32px;
    border-radius: 24px;
    background: var(--bg-card);
    border: 1px solid var(--color-border);
    margin-top: 4rem;
  }

  .contact-banner h2 {
    margin-bottom: 1rem;
  }

  .contact-banner p {
    margin-bottom: 2rem;
  }

  @media (max-width: 640px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-card { padding: 20px; gap: 16px; }
  }
</style>
