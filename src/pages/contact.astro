---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontak" description="Hubungi Fatahilah Miftahul Rahman - Kolaborasi Infrastruktur Jaringan, Server, dan AI Prompt Engineering">
  <section class="contact-section container section-py">
    <div class="section-header">
      <div class="section-badge">
        <span class="badge font-mono" data-i18n="nav.contact">Kontak</span>
      </div>
      <h1 class="font-heading" data-i18n="contact.title">Hubungi & Terhubung</h1>
      <p class="section-subtitle" data-i18n="contact.intro">
        Tertarik untuk berkolaborasi, berdiskusi tentang infrastruktur jaringan, atau konsultasi AI Prompt Engineering? Silakan hubungi saya melalui saluran di bawah ini.
      </p>
    </div>

    <!-- Contact Channels Grid -->
    <div class="contact-grid">
      <!-- WhatsApp Card -->
      <a href="https://wa.me/6281234567890" target="_blank" rel="noopener noreferrer" class="contact-card glass-card">
        <div class="icon-circle icon-green">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <div class="channel-info">
          <h2 class="channel-title font-heading">WhatsApp Direct</h2>
          <p class="channel-desc font-mono">+62 812-XXXX-XXXX</p>
        </div>
        <span class="btn-primary channel-btn" data-i18n="contact.btn.wa">Kirim Pesan WhatsApp</span>
      </a>

      <!-- LinkedIn Card -->
      <a href="https://linkedin.com/in/fatahilahmr" target="_blank" rel="noopener noreferrer" class="contact-card glass-card">
        <div class="icon-circle icon-blue">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </div>
        <div class="channel-info">
          <h2 class="channel-title font-heading">LinkedIn Profile</h2>
          <p class="channel-desc font-mono">linkedin.com/in/fatahilahmr</p>
        </div>
        <span class="btn-secondary channel-btn" data-i18n="contact.btn.linkedin">Terhubung di LinkedIn</span>
      </a>

      <!-- GitHub Card -->
      <a href="https://github.com/fatahilahmr" target="_blank" rel="noopener noreferrer" class="contact-card glass-card">
        <div class="icon-circle icon-cyan">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </div>
        <div class="channel-info">
          <h2 class="channel-title font-heading">GitHub Repository & Lab</h2>
          <p class="channel-desc font-mono">github.com/fatahilahmr</p>
        </div>
        <span class="btn-secondary channel-btn" data-i18n="contact.btn.github">Lihat Repositori GitHub</span>
      </a>

      <!-- Email Direct Card -->
      <a href="mailto:fatahilahmr@example.com" class="contact-card glass-card">
        <div class="icon-circle icon-gold">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </div>
        <div class="channel-info">
          <h2 class="channel-title font-heading">Direct Email</h2>
          <p class="channel-desc font-mono">fatahilahmr@example.com</p>
        </div>
        <span class="btn-secondary channel-btn" data-i18n="contact.btn.email">Kirim Email Langsung</span>
      </a>
    </div>
  </section>
</Layout>

<style>
  .section-header { text-align: center; max-width: 760px; margin: 0 auto 56px; }
  .section-badge { margin-bottom: 16px; }
  .section-subtitle { font-size: 1.1rem; margin-top: 12px; }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 28px;
    max-width: 960px;
    margin: 0 auto;
  }

  .contact-card {
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    text-decoration: none;
  }

  .icon-circle {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-green { background: rgba(16, 185, 129, 0.15); color: #10B981; }
  .icon-blue { background: rgba(59, 130, 246, 0.15); color: var(--color-primary); }
  .icon-cyan { background: rgba(6, 182, 212, 0.15); color: var(--color-cyan); }
  .icon-gold { background: rgba(245, 158, 11, 0.15); color: var(--color-accent); }

  .channel-title { font-size: 1.4rem; }
  .channel-desc { font-size: 0.9rem; color: var(--color-muted); }
  .channel-btn { width: 100%; margin-top: auto; }

  @media (max-width: 640px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-card { padding: 28px 20px; }
  }
</style>
