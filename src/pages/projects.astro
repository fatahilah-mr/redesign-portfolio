---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Proyek & Lab Archive" description="Galeri dokumentasi proyek teknis, eksperimen lab jaringan, Cisco, MikroTik, Linux, AI, Windows Server, dan pembuatan website Fatahilah Miftahul Rahman.">
  <section class="projects-section container section-py">
    <div class="section-header">
      <div class="section-badge flex justify-center items-center gap-3">
        <span class="badge font-mono" data-i18n="nav.projects">Proyek Teknis</span>
        <span class="badge badge-primary font-mono">Google Sheets CMS</span>
      </div>
      <h1 class="font-heading" data-i18n="projects.title">Lab Archive & Proyek Portofolio</h1>
      <p class="section-subtitle">
        Dokumentasi langsung dari eksperimen laboratorium infrastruktur, konfigurasi server, serta proyek pengembangan teknologi terapan.
      </p>

      <!-- CMS Actions & Caching Info -->
      <div class="cms-toolbar mt-6 flex flex-wrap justify-center items-center gap-4">
        <button id="refresh-projects-btn" class="btn-refresh font-mono text-xs flex items-center gap-2" aria-label="Segarkan data Proyek dari Google Sheets">
          <svg class="refresh-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
          <span>↻ Segarkan Data CMS</span>
        </button>
        <span id="projects-cache-status" class="cache-status font-mono text-xs text-muted">Status: Memuat data...</span>
      </div>
    </div>

    <!-- Category Filter Buttons (Exact Categories from cms logic) -->
    <div class="cert-buttons-wrapper flex flex-wrap justify-center gap-3 mb-10" role="group" aria-label="Filter Kategori Proyek">
      <button class="cert-btn btn-secondary active-filter" data-category="all">Semua Proyek</button>
      <button class="cert-btn btn-secondary" data-category="AI">AI</button>
      <button class="cert-btn btn-secondary" data-category="Cisco">Cisco</button>
      <button class="cert-btn btn-secondary" data-category="Linux">Linux</button>
      <button class="cert-btn btn-secondary" data-category="MikroTik">MikroTik</button>
      <button class="cert-btn btn-secondary" data-category="Windows Server">Windows Server</button>
      <button class="cert-btn btn-secondary" data-category="Website">Website</button>
    </div>

    <!-- Projects Grid Container (Dynamically rendered by app.js logic) -->
    <div id="projects-grid" class="projects-grid" aria-live="polite">
      <div class="loading-status glass-card p-12 text-center col-span-full">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary mb-4"></div>
        <p class="font-heading text-lg">Menghubungkan ke API Google Sheets (Database_App)...</p>
        <p class="text-muted text-sm mt-1">Mengambil arsip proyek terbaru dari server</p>
      </div>
    </div>
  </section>
</Layout>

<!-- CMS Logic Script (Exact from cms logic/halaman projects & lab/app.js with 1h localStorage caching) -->
<script is:inline>
(function() {
  // 1. Konfigurasi Database Google Sheets API Baru (Sesuai app.js)
  const SPREADSHEET_ID = '1YMxR6-SlP-TT0B3y6NScT4L0YH0GXZEId_PY0Jgp8fQ';
  const SHEET_NAME = 'Database_App'; 
  const GOOGLE_SHEETS_URL = `https://docs.google.com/spreadsheets/d/${SPREADSHEET_ID}/gviz/tq?tqx=out:json&sheet=${SHEET_NAME}`;
  const CACHE_KEY = 'portfolio_projects_cache_v2';
  const CACHE_TIME_KEY = 'portfolio_projects_cache_time_v2';
  const CACHE_DURATION_MS = 3600000; // 1 jam

  let localProjectsData = [];

  const projectsGrid = document.getElementById('projects-grid');
  const filterButtons = document.querySelectorAll('.cert-btn');
  const refreshBtn = document.getElementById('refresh-projects-btn');
  const cacheStatus = document.getElementById('projects-cache-status');

  // UTILITY: ESCAPE HTML (XSS Protection)
  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/[&<>'"]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      if (m === "'") return '&#039;';
      if (m === '"') return '&quot;';
      return m;
    });
  }

  function updateCacheStatusText(msg) {
    if (cacheStatus) cacheStatus.textContent = msg;
  }

  // 3. WARNA BADGE BERDASARKAN KATEGORI (Sesuai app.js)
  function getBadgeClass(kategori) {
    if (!kategori) return 'badge-default';
    const kat = kategori.toLowerCase().trim();
    if (kat === 'ai') return 'badge-ai';
    if (kat === 'cisco') return 'badge-cisco';
    if (kat === 'linux') return 'badge-linux';
    if (kat === 'mikrotik') return 'badge-mikrotik';
    if (kat === 'windows server') return 'badge-windows';
    if (kat === 'website') return 'badge-website';
    return 'badge-default';
  }

  // 4. FUNGSI BAGIKAN (SHARE)
  async function shareProject(url, title) {
    if (!url || url === '#' || url === '') {
      alert('Tidak ada link dokumentasi untuk proyek ini.');
      return;
    }
    const shareData = {
      title: title,
      text: 'Lihat proyek ini di Lab Archive saya:',
      url: url
    };
    if (navigator.share) {
      try {
        await navigator.share(shareData);
      } catch (err) {
        if (err.name !== 'AbortError') {
          console.warn('Gagal membagikan:', err);
          fallbackCopy(url);
        }
      }
    } else {
      fallbackCopy(url);
    }
  }

  function fallbackCopy(url) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(url).then(() => {
        alert('Link dokumentasi telah disalin ke clipboard!');
      }).catch(() => {
        alert('Gagal menyalin link. Silakan salin manual: ' + url);
      });
    } else {
      alert('Silakan salin manual link berikut: ' + url);
    }
  }

  // 5. RENDER KARTU PROYEK (Sesuai app.js)
  function renderProjects(projects) {
    if (!projectsGrid) return;
    projectsGrid.innerHTML = '';

    if (!projects || projects.length === 0) {
      projectsGrid.innerHTML = `
        <div class="loading-status glass-card p-12 text-center col-span-full">
          <p class="font-heading text-lg text-muted">Tidak ada proyek dalam kategori ini.</p>
        </div>
      `;
      return;
    }

    projects.forEach(project => {
      const card = document.createElement('div');
      card.className = 'project-card glass-card';
      
      const imgUrl = project.link_gambar ? project.link_gambar : 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=600';
      const badgeClass = getBadgeClass(project.kategori);
      
      const judulEscaped = escapeHtml(project.judul);
      const deskripsiEscaped = escapeHtml(project.deskripsi);
      const kategoriEscaped = escapeHtml(project.kategori);
      const linkEscaped = escapeHtml(project.link_dokumentasi || '#');
      
      card.innerHTML = `
        <div class="project-img-wrap">
          <img src="${imgUrl}" alt="Preview ${judulEscaped}" loading="lazy" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=600';">
        </div>
        <div class="project-info">
          <div>
            <span class="project-badge ${badgeClass}">${kategoriEscaped}</span>
            <h3 class="project-title font-heading">${judulEscaped}</h3>
            <p class="project-desc text-muted">${deskripsiEscaped}</p>
          </div>
          <div class="project-actions mt-auto pt-4 border-t border-border flex justify-between items-center gap-3">
            <a href="${linkEscaped}" target="_blank" rel="noopener noreferrer" class="project-link btn-primary text-xs py-2 px-3 flex items-center gap-1.5">
              <span>Lihat Dokumentasi</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
            </a>
            <button class="project-share btn-secondary text-xs py-2 px-3 flex items-center gap-1.5" data-url="${linkEscaped}" data-title="${judulEscaped}">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              <span>Bagikan</span>
            </button>
          </div>
        </div>
      `;
      
      projectsGrid.appendChild(card);
      
      const shareBtn = card.querySelector('.project-share');
      if (shareBtn) {
        shareBtn.addEventListener('click', (e) => {
          e.preventDefault();
          const url = shareBtn.getAttribute('data-url');
          const title = shareBtn.getAttribute('data-title');
          shareProject(url, title);
        });
      }
    });
  }

  // 2. AMBIL DATA DARI GOOGLE SHEETS
  async function fetchProjectsData(forceRefresh = false) {
    // Cek cache terlebih dahulu jika tidak dipaksa refresh
    if (!forceRefresh) {
      try {
        const cached = localStorage.getItem(CACHE_KEY);
        const cachedTime = localStorage.getItem(CACHE_TIME_KEY);
        if (cached && cachedTime) {
          const now = Date.now();
          if (now - parseInt(cachedTime, 10) < CACHE_DURATION_MS) {
            localProjectsData = JSON.parse(cached);
            renderProjects(localProjectsData);
            const remainingMins = Math.round((CACHE_DURATION_MS - (now - parseInt(cachedTime, 10))) / 60000);
            updateCacheStatusText(`Status: Data dari Cache (${remainingMins}m tersisa)`);
            return;
          }
        }
      } catch (e) {
        console.warn('Gagal membaca cache:', e);
      }
    }

    updateCacheStatusText('Status: Mengambil dari Google Sheets...');
    if (refreshBtn) refreshBtn.classList.add('loading');

    try {
      const response = await fetch(GOOGLE_SHEETS_URL);
      if (!response.ok) throw new Error('Gagal mengakses URL spreadsheet');
      
      const rawText = await response.text();
      const jsonMatch = rawText.match(/google\.visualization\.Query\.setResponse\(([\s\S]*?)\);/);
      if (!jsonMatch) throw new Error('Respons JSON tidak valid dari Google Sheets');
      
      const data = JSON.parse(jsonMatch[1]);
      const rows = data.table.rows || [];
      
      localProjectsData = rows.map(row => {
        return {
          id: row.c[0] ? row.c[0].v : '',
          timestamp: row.c[1] ? row.c[1].v : '',
          judul: row.c[2] ? row.c[2].v : 'Tanpa Judul',
          kategori: row.c[3] ? row.c[3].v : 'Umum',
          link_dokumentasi: row.c[4] ? row.c[4].v : '#',
          deskripsi: row.c[5] ? row.c[5].v : 'Tidak ada deskripsi.',
          link_gambar: row.c[6] ? row.c[6].v : ''
        };
      });

      // Simpan ke localStorage
      try {
        localStorage.setItem(CACHE_KEY, JSON.stringify(localProjectsData));
        localStorage.setItem(CACHE_TIME_KEY, Date.now().toString());
      } catch (e) {
        console.warn('Gagal menyimpan cache:', e);
      }

      renderProjects(localProjectsData);
      updateCacheStatusText('Status: Pembaruan Live Berhasil (Cache 1 Jam)');
    } catch (error) {
      console.error('Error fetching data:', error);
      
      // Coba load cache lama jika gagal fetch online
      try {
        const cached = localStorage.getItem(CACHE_KEY);
        if (cached) {
          localProjectsData = JSON.parse(cached);
          renderProjects(localProjectsData);
          updateCacheStatusText('Status: Offline (Menampilkan Cache Terakhir)');
          if (refreshBtn) refreshBtn.classList.remove('loading');
          return;
        }
      } catch (e) {}

      // Jika tidak ada cache, tampilkan data statis terverifikasi
      localProjectsData = [
        {
          id: "1",
          judul: "Rancang Bangun Jaringan Kantor 3 Lantai (Cisco Packet Tracer)",
          kategori: "Cisco",
          link_dokumentasi: "https://github.com/fatahilah-mr/portofolio",
          deskripsi: "Perancangan infrastruktur jaringan lengkap menggunakan Cisco Packet Tracer dengan segmentasi VLAN, inter-VLAN routing, OSPF, DHCP Relay, dan pengamanan Port Security.",
          link_gambar: "/assets/Topologi-Cisco-PT-01.webp"
        },
        {
          id: "2",
          judul: "Setup Gateway, Firewall Nftables & Keamanan Jaringan MikroTik",
          kategori: "MikroTik",
          link_dokumentasi: "https://github.com/fatahilah-mr/portofolio",
          deskripsi: "Konfigurasi RouterBoard MikroTik sebagai gateway internet, manajemen bandwidth Queue Tree, isolasi jaringan tamu, dan pengamanan akses menggunakan Nftables/Firewall Filter.",
          link_gambar: "/assets/Mikrotik-01.webp"
        }
      ];
      renderProjects(localProjectsData);
      updateCacheStatusText('Status: Offline (Menampilkan Data Fallback)');
    } finally {
      if (refreshBtn) refreshBtn.classList.remove('loading');
    }
  }

  // 6. LOGIKA FILTER KATEGORI
  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      filterButtons.forEach(btn => btn.classList.remove('active-filter'));
      button.classList.add('active-filter');

      const selectedCategory = button.getAttribute('data-category');

      if (selectedCategory === 'all') {
        renderProjects(localProjectsData);
      } else {
        const filtered = localProjectsData.filter(p => (p.kategori || '').toLowerCase().trim() === selectedCategory.toLowerCase().trim());
        renderProjects(filtered);
      }
    });
  });

  if (refreshBtn) {
    refreshBtn.addEventListener('click', () => fetchProjectsData(true));
  }

  // 9. JALANKAN FETCH SAAT DOM SIAP
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => fetchProjectsData(false));
  } else {
    fetchProjectsData(false);
  }
})();
</script>

<style>
  .section-header { text-align: center; max-width: 800px; margin: 0 auto 36px; }
  .section-subtitle { font-size: 1.1rem; margin-top: 12px; }

  .btn-refresh {
    padding: 6px 14px;
    border-radius: 20px;
    background: var(--bg-surface);
    border: 1px solid var(--color-border);
    color: var(--color-foreground);
    transition: all 0.2s ease;
  }
  .btn-refresh:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .btn-refresh.loading .refresh-icon { animation: spin 1s linear infinite; }
  @keyframes spin { 100% { transform: rotate(360deg); } }

  /* Category Filter Buttons */
  .cert-btn {
    padding: 8px 18px;
    border-radius: 30px;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .cert-btn.active-filter {
    background: var(--color-primary);
    color: #000;
    border-color: var(--color-primary);
    box-shadow: 0 0 16px rgba(255, 179, 0, 0.4);
  }

  /* Projects Grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 32px;
  }

  /* Project Cards */
  .project-card {
    border-radius: 22px;
    background: var(--bg-card);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .project-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-lg);
  }

  .project-img-wrap {
    width: 100%;
    height: 210px;
    overflow: hidden;
    background: var(--bg-surface);
    position: relative;
  }
  .project-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .project-card:hover .project-img-wrap img {
    transform: scale(1.06);
  }

  .project-info {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 12px;
  }

  .project-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }

  /* Badge colors exactly matching getBadgeClass logic */
  .badge-ai { background: rgba(168, 85, 247, 0.15); color: #c084fc; border: 1px solid rgba(168, 85, 247, 0.3); }
  .badge-cisco { background: rgba(56, 189, 248, 0.15); color: #38bdf8; border: 1px solid rgba(56, 189, 248, 0.3); }
  .badge-linux { background: rgba(250, 204, 21, 0.15); color: #facc15; border: 1px solid rgba(250, 204, 21, 0.3); }
  .badge-mikrotik { background: rgba(248, 113, 113, 0.15); color: #f87171; border: 1px solid rgba(248, 113, 113, 0.3); }
  .badge-windows { background: rgba(96, 165, 250, 0.15); color: #60a5fa; border: 1px solid rgba(96, 165, 250, 0.3); }
  .badge-website { background: rgba(52, 211, 153, 0.15); color: #34d399; border: 1px solid rgba(52, 211, 153, 0.3); }
  .badge-default { background: rgba(255, 179, 0, 0.15); color: var(--color-primary); border: 1px solid rgba(255, 179, 0, 0.3); }

  .project-title {
    font-size: 1.3rem;
    line-height: 1.35;
    color: var(--color-foreground);
  }

  .project-desc {
    font-size: 0.94rem;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .projects-grid { grid-template-columns: 1fr; }
    .project-info { padding: 20px; }
  }
</style>
