---
import { ui, defaultLang } from '../i18n/ui';
---

<div class="floating-lang-wrapper">
  <button 
    id="lang-toggle-btn" 
    class="floating-lang-btn" 
    aria-label="Switch between Indonesian and English language"
    title="Ganti Bahasa / Switch Language"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lang-globe-icon" aria-hidden="true">
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
      <path d="M2 12h20"></path>
    </svg>
    <span class="lang-text font-mono" id="current-lang-code">ID</span>
  </button>
</div>

<style>
  .floating-lang-wrapper {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 990;
  }

  .floating-lang-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 9999px;
    background: var(--bg-card);
    border: 1px solid var(--color-border);
    color: var(--color-foreground);
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    box-shadow: var(--shadow-md);
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .floating-lang-btn:hover {
    transform: translateY(-3px) scale(1.02);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-lg), 0 0 15px var(--color-primary-glow);
    background: var(--bg-card-hover);
  }

  .lang-flag {
    font-size: 1.15rem;
    line-height: 1;
  }

  .lang-text {
    letter-spacing: 0.05em;
  }
</style>

