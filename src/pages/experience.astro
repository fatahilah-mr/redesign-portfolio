---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pengalaman & Pendidikan" description="Riwayat Pengalaman Kerja Lapangan (PKL) dan Pendidikan Fatahilah Miftahul Rahman">
  <section class="experience-section container section-py">
    <div class="section-header">
      <div class="section-badge">
        <span class="badge font-mono" data-i18n="nav.experience">Pengalaman</span>
      </div>
      <h1 class="font-heading" data-i18n="exp.title">Riwayat Pengalaman & Pendidikan</h1>
      <p class="section-subtitle">Jejak dedikasi teknis di lingkungan profesional enterprise dan pencapaian akademik.</p>
    </div>

    <!-- Timeline / Grid Experience -->
    <div class="timeline-container">
      <!-- PKL Card -->
      <div class="timeline-card glass-card">
        <div class="card-top">
          <div class="role-badge font-mono">
            <span class="pulse-dot"></span> PKL / Internship
          </div>
          <span class="period font-mono">2025 - 2026</span>
        </div>

        <h2 class="role-title font-heading" data-i18n="exp.pkl.role">
          Praktik Kerja Lapangan (PKL) - IT Network Administrator
        </h2>
        
        <p class="role-desc" data-i18n="exp.pkl.desc">
          Melakukan pemeliharaan perangkat jaringan, troubleshooting koneksi LAN/WLAN, konfigurasi VLAN, serta pemantauan kinerja server dan keamanan jaringan di lingkungan kerja profesional.
        </p>

        <!-- Locations Grid -->
        <div class="locations-grid font-mono">
          <div class="loc-pill">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span data-i18n="exp.pkl.loc1">UPTD BLK Kebumen</span>
          </div>
          <div class="loc-pill">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span data-i18n="exp.pkl.loc2">Fazza Computer</span>
          </div>
          <div class="loc-pill">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span data-i18n="exp.pkl.loc3">IMC Computer</span>
          </div>
        </div>
      </div>

      <!-- Education Card -->
      <div class="timeline-card glass-card card-gold">
        <div class="card-top">
          <div class="role-badge badge-gold font-mono">
            🏆 Pendidikan & Prestasi
          </div>
          <span class="period font-mono">SMK TKJ</span>
        </div>

        <h2 class="role-title font-heading" data-i18n="exp.edu.school">
          SMK - Teknik Komputer dan Jaringan (TKJ)
        </h2>
        
        <p class="role-desc text-accent font-mono" data-i18n="exp.edu.achieve">
          Juara 1 Lomba Kompetensi Siswa (LKS) Bidang IT Network System Administration tingkat Kabupaten Purworejo 2026.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 56px;
  }

  .section-badge {
    margin-bottom: 16px;
  }

  .section-subtitle {
    font-size: 1.1rem;
    margin-top: 12px;
  }

  .timeline-container {
    display: flex;
    flex-direction: column;
    gap: 32px;
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline-card {
    padding: 36px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    border-left: 4px solid var(--color-primary);
  }

  .card-gold {
    border-left-color: var(--color-accent);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .role-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 9999px;
    background: rgba(59, 130, 246, 0.15);
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 8px var(--color-primary);
  }

  .period {
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .role-title {
    font-size: 1.65rem;
  }

  .role-desc {
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .text-accent {
    color: var(--color-accent);
    font-weight: 500;
  }

  .locations-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 8px;
  }

  .loc-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 10px;
    background: var(--bg-surface);
    border: 1px solid var(--color-border);
    font-size: 0.875rem;
    color: var(--color-foreground);
  }

  @media (max-width: 640px) {
    .timeline-card {
      padding: 24px;
    }
  }
</style>
